---
import { content, type Locale } from "../i18n";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].runtimeMarquee;
const doubled = [...c.chips, ...c.chips];
---

<section
  id="runtime-marquee"
  class="border-y border-[color:var(--color-ink-border)]/50 py-20 sm:py-24"
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <span class="mol-eyebrow">{c.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {c.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {c.subtitle}
      </p>
    </div>
  </div>

  <div class="mt-12 mol-marquee" aria-hidden="false">
    <div class="mol-marquee-track">
      {
        doubled.map((chip) => (
          <div class="mol-marquee-chip">
            <span class="font-mono text-sm font-semibold text-white">{chip.label}</span>
            <span class="text-xs text-[color:var(--color-fg-muted)]">{chip.detail}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mol-marquee {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .mol-marquee-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: mol-marquee-scroll 38s linear infinite;
  }
  .mol-marquee:hover .mol-marquee-track {
    animation-play-state: paused;
  }
  .mol-marquee-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    border: 1px solid var(--color-ink-border-strong, rgba(255, 255, 255, 0.1));
    background: color-mix(in srgb, var(--color-ink-soft, rgb(20, 20, 24)) 60%, transparent);
    border-radius: 0.625rem;
    white-space: nowrap;
  }
  @keyframes mol-marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mol-marquee-track {
      animation: none;
    }
  }
</style>
