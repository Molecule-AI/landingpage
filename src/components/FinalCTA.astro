---
import { content, type Locale } from "../i18n";
import ShapeGrid from "./ShapeGrid.astro";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].finalCta;
---

<section class="relative isolate overflow-hidden py-28 sm:py-36">
  <div
    class="absolute inset-0 -z-10"
    style="background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(127,232,214,0.14), transparent 70%);"
    aria-hidden="true"
  >
  </div>
  <ShapeGrid class="-z-10 opacity-70" />

  <div class="mx-auto max-w-4xl px-6 text-center" data-reveal>
    <p class="mb-8 text-pretty text-xs font-medium italic text-[color:var(--color-fg-dim)] sm:text-sm">
      {c.vision}
    </p>

    <span class="mol-eyebrow">{c.eyebrow}</span>

    <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-6xl">
      {c.titleTop}
      <span class="mol-gradient-text block pt-2">{c.titleBottom}</span>
    </h2>

    <p class="mx-auto mt-6 max-w-xl text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
      {c.subtitle}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {
        c.actions.map((action) => (
          <a
            href={action.href}
            class={action.primary ? "mol-btn-primary" : "mol-btn-secondary"}
            rel={action.href.startsWith("http") ? "noopener" : undefined}
          >
            {action.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
