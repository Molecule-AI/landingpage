---
import { content, type Locale } from "../i18n";
import HexBg from "./HexBg.astro";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale];
const h = c.hero;
const d = c.dashboard;
---

<section class="relative isolate overflow-hidden pt-20 pb-20 sm:pt-28 sm:pb-28">
  <HexBg id="hex-hero" class="-z-10" />

  <div class="mol-orb mol-orb--mint -z-10" style="width:520px;height:520px;top:-180px;left:50%;transform:translateX(-50%);" aria-hidden="true"></div>
  <div class="mol-orb mol-orb--cyan -z-10" style="width:380px;height:380px;top:120px;left:-120px;" aria-hidden="true"></div>
  <div class="mol-orb mol-orb--deep -z-10" style="width:420px;height:420px;top:220px;right:-160px;opacity:0.4;" aria-hidden="true"></div>

  <div class="mx-auto max-w-6xl px-6 text-center">
    <div class="mb-7 inline-flex">
      <span class="mol-eyebrow">{h.badge}</span>
    </div>

    <h1
      class="mx-auto max-w-4xl text-balance text-[2.5rem] font-bold leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl"
    >
      {h.titleLead}
      <span class="mol-gradient-text block pt-2">{h.titleHighlight}</span>
    </h1>

    <p
      class="mx-auto mt-7 max-w-2xl text-pretty text-base leading-relaxed text-[color:var(--color-fg-muted)] sm:text-lg"
    >
      {h.description}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href={h.primaryCta.href} class="mol-btn-primary">
        {h.primaryCta.label}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <a href={h.secondaryCta.href} class="mol-btn-secondary" rel="noopener">
        {h.secondaryCta.label}
      </a>
    </div>

    <!-- Control Plane dashboard mockup -->
    <div class="relative mx-auto mt-16 max-w-5xl text-left">
      <div class="mol-dashboard">
        <div class="mol-dashboard-chrome">
          <div class="flex items-center gap-4">
            <div class="mol-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <div class="mol-dashboard-title">{d.title}</div>
          </div>
          <div class="mol-live">
            <span class="mol-live-dot" aria-hidden="true"></span>
            {d.liveLabel}
          </div>
        </div>

        <div class="mol-dashboard-body">
          <!-- Organization root -->
          <div class="mol-root-card">
            <div>
              <div class="mol-root-name">{d.rootName}</div>
              <div class="mol-root-path">{d.rootPath}</div>
            </div>
            <div class="mol-root-tags">
              {d.rootMeta.map((tag) => <span class="mol-tag">{tag}</span>)}
            </div>
          </div>

          <!-- Team grid -->
          <div class="mol-team-grid">
            {
              d.teams.map((team) => (
                <article class="mol-team">
                  <header class="mol-team-head">
                    <div>
                      <div class="mol-team-name">{team.name}</div>
                      <div class="mol-team-sub">{team.subtitle}</div>
                    </div>
                    <span class={`mol-status mol-status--${team.status === "IDLE" || team.status === "空闲" ? "idle" : "active"}`}>
                      {team.status}
                    </span>
                  </header>
                  <div class="flex flex-col gap-1.5">
                    {
                      team.agents.map((agent) => (
                        <div class="mol-agent">
                          <span class={`mol-agent-dot mol-agent-dot--${agent.state}`} aria-hidden="true" />
                          <div class="mol-agent-body">
                            <div class="mol-agent-name">{agent.name}</div>
                            <div class="mol-agent-model">{agent.model}</div>
                          </div>
                        </div>
                      ))
                    }
                  </div>
                  <div class="mol-team-scope">MEMORY · {team.scope}</div>
                </article>
              ))
            }
          </div>

          <!-- Stats footer -->
          <div class="mol-stats">
            {
              d.footerStats.map((stat) => (
                <div class="mol-stat">
                  <div class="mol-stat-val">{stat.value}</div>
                  <div class="mol-stat-label">{stat.label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
