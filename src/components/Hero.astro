---
import { hero } from "../data/content";
---

<section class="relative overflow-hidden pt-20 pb-24 sm:pt-28 sm:pb-32">
  <div class="mol-grid absolute inset-0 -z-10"></div>
  <div
    class="absolute inset-x-0 top-0 -z-10 h-[640px]"
    style="background: radial-gradient(ellipse 60% 60% at 50% 0%, rgba(127,232,214,0.18), transparent 70%);"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 text-center">
    <div class="mb-7 inline-flex">
      <span class="mol-eyebrow">{hero.badge}</span>
    </div>

    <h1
      class="mx-auto max-w-4xl text-balance text-[2.5rem] font-bold leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl"
    >
      {hero.titleLead}
      <span class="mol-gradient-text block pt-2">{hero.titleHighlight}</span>
    </h1>

    <p
      class="mx-auto mt-7 max-w-2xl text-pretty text-base leading-relaxed text-[color:var(--color-fg-muted)] sm:text-lg"
    >
      {hero.description}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href={hero.primaryCta.href} class="mol-btn-primary">
        {hero.primaryCta.label}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <a href={hero.secondaryCta.href} class="mol-btn-secondary" rel="noopener">
        {hero.secondaryCta.label}
      </a>
    </div>

    <!-- Molecule visual motif -->
    <div class="relative mx-auto mt-20 max-w-4xl">
      <div
        class="mol-panel rounded-2xl p-8 sm:p-12"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 800 300"
          class="w-full h-auto"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <radialGradient id="nodeGrad" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#a8f0e1" />
              <stop offset="100%" stop-color="#3aa690" />
            </radialGradient>
            <linearGradient id="edgeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#7fe8d6" stop-opacity="0.1" />
              <stop offset="50%" stop-color="#7fe8d6" stop-opacity="0.8" />
              <stop offset="100%" stop-color="#7fe8d6" stop-opacity="0.1" />
            </linearGradient>
          </defs>

          <!-- Edges -->
          <g stroke="url(#edgeGrad)" stroke-width="1.5" fill="none">
            <line x1="400" y1="150" x2="180" y2="60" />
            <line x1="400" y1="150" x2="620" y2="60" />
            <line x1="400" y1="150" x2="140" y2="180" />
            <line x1="400" y1="150" x2="660" y2="180" />
            <line x1="400" y1="150" x2="300" y2="250" />
            <line x1="400" y1="150" x2="500" y2="250" />
            <line x1="180" y1="60" x2="140" y2="180" />
            <line x1="620" y1="60" x2="660" y2="180" />
            <line x1="300" y1="250" x2="500" y2="250" />
          </g>

          <!-- Secondary nodes -->
          <g fill="url(#nodeGrad)" opacity="0.85">
            <circle cx="180" cy="60" r="14" />
            <circle cx="620" cy="60" r="14" />
            <circle cx="140" cy="180" r="14" />
            <circle cx="660" cy="180" r="14" />
            <circle cx="300" cy="250" r="14" />
            <circle cx="500" cy="250" r="14" />
          </g>

          <!-- Center node -->
          <circle cx="400" cy="150" r="28" fill="url(#nodeGrad)" />
          <circle cx="400" cy="150" r="44" fill="none" stroke="#7fe8d6" stroke-width="1" opacity="0.3" />
          <circle cx="400" cy="150" r="64" fill="none" stroke="#7fe8d6" stroke-width="1" opacity="0.15" />

          <!-- Labels -->
          <g fill="#8fa3bf" font-family="Inter, system-ui, sans-serif" font-size="11" font-weight="500">
            <text x="180" y="42" text-anchor="middle">Claude Code</text>
            <text x="620" y="42" text-anchor="middle">LangGraph</text>
            <text x="140" y="210" text-anchor="middle">CrewAI</text>
            <text x="660" y="210" text-anchor="middle">AutoGen</text>
            <text x="300" y="280" text-anchor="middle">DeepAgents</text>
            <text x="500" y="280" text-anchor="middle">OpenClaw</text>
          </g>
          <text x="400" y="154" text-anchor="middle" fill="#04121a" font-family="Inter, system-ui, sans-serif" font-size="11" font-weight="700">MOLECULE</text>
        </svg>
      </div>
    </div>
  </div>
</section>
