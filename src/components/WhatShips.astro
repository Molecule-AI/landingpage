---
import { content, type Locale } from "../i18n";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].whatShips;
---

<section id="ships" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <span class="mol-eyebrow">{c.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {c.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {c.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-2" data-reveal="stagger">
      {
        c.columns.map((col, i) => (
          <article class="mol-panel mol-panel-hover rounded-2xl p-8 sm:p-10" style={`--i: ${i}`}>
            <div class="mb-2 font-mono text-[11px] font-bold tracking-[0.2em] text-[color:var(--color-mint)]">
              {col.label}
            </div>
            <h3 class="text-2xl font-semibold text-white sm:text-3xl">{col.name}</h3>
            <p class="mt-3 font-mono text-xs text-[color:var(--color-fg-muted)]">
              {col.stack}
            </p>
            <ul class="mt-6 space-y-3">
              {
                col.items.map((item) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-[color:var(--color-fg)]">
                    <svg
                      class="mt-1 flex-shrink-0"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      style="color: var(--color-mint);"
                      aria-hidden="true"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
