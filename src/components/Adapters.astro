---
import { adapters } from "../data/content";
---

<section id="adapters" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="mol-eyebrow">{adapters.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {adapters.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {adapters.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        adapters.cards.map((card) => (
          <article class="mol-panel mol-panel-hover flex flex-col rounded-2xl p-7">
            <h3 class="text-lg font-semibold text-white">{card.title}</h3>
            <p class="mt-3 text-sm font-medium text-[color:var(--color-mint)]">
              {card.headline}
            </p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-[color:var(--color-fg-muted)]">
              {card.detail}
            </p>
            <ul class="mt-6 flex flex-wrap gap-2">
              {
                card.items.map((item) => (
                  <li class="rounded-md border border-[color:var(--color-ink-border-strong)] bg-[color:var(--color-ink-soft)]/50 px-2.5 py-1 font-mono text-xs text-[color:var(--color-fg)]">
                    {item}
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
