---
interface Props {
  id?: string;
  opacity?: number;
  accented?: boolean;
  masked?: boolean;
  class?: string;
}
const {
  id = "hex",
  opacity = 0.18,
  accented = true,
  masked = true,
  class: className = "",
} = Astro.props;

const maskStyle = masked
  ? "mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 25%, transparent 88%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 25%, transparent 88%);"
  : "";
---

<svg
  class={`pointer-events-none absolute inset-0 h-full w-full ${className}`}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1200 900"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  style={maskStyle}
>
  <defs>
    <pattern
      id={id}
      x="0"
      y="0"
      width="56"
      height="100"
      patternUnits="userSpaceOnUse"
    >
      <path
        d="M28 66 L0 50 L0 16 L28 0 L56 16 L56 50 Z M28 100 L0 84 L0 50 L28 34 L56 50 L56 84 Z"
        fill="none"
        stroke={`rgba(127, 232, 214, ${opacity})`}
        stroke-width="1"
      />
    </pattern>
    <radialGradient id={`${id}-glow`} cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="rgba(127,232,214,0.6)" />
      <stop offset="100%" stop-color="rgba(127,232,214,0)" />
    </radialGradient>
  </defs>

  <rect width="100%" height="100%" fill={`url(#${id})`} />

  {
    accented && (
      <g class="mol-hex-accents">
        <path
          class="mol-hex-glow mol-hex-glow-1"
          d="M336 166 L280 150 L280 116 L336 100 L392 116 L392 150 Z"
          fill="rgba(127,232,214,0.14)"
          stroke="rgba(127,232,214,0.55)"
          stroke-width="1.6"
        />
        <path
          class="mol-hex-glow mol-hex-glow-2"
          d="M840 266 L784 250 L784 216 L840 200 L896 216 L896 250 Z"
          fill="rgba(94,227,207,0.12)"
          stroke="rgba(94,227,207,0.5)"
          stroke-width="1.6"
        />
        <path
          class="mol-hex-glow mol-hex-glow-3"
          d="M504 466 L448 450 L448 416 L504 400 L560 416 L560 450 Z"
          fill="rgba(127,232,214,0.1)"
          stroke="rgba(127,232,214,0.48)"
          stroke-width="1.6"
        />
        <path
          class="mol-hex-glow mol-hex-glow-4"
          d="M1008 566 L952 550 L952 516 L1008 500 L1064 516 L1064 550 Z"
          fill="rgba(94,227,207,0.08)"
          stroke="rgba(94,227,207,0.42)"
          stroke-width="1.6"
        />
        <path
          class="mol-hex-glow mol-hex-glow-5"
          d="M224 666 L168 650 L168 616 L224 600 L280 616 L280 650 Z"
          fill="rgba(127,232,214,0.12)"
          stroke="rgba(127,232,214,0.5)"
          stroke-width="1.6"
        />
      </g>
    )
  }
</svg>
