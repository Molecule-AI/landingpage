---
import { whyNow } from "../data/content";
---

<section id="why-now" class="border-y border-[color:var(--color-ink-border)]/50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="mol-eyebrow">{whyNow.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {whyNow.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {whyNow.subtitle}
      </p>
    </div>

    <ul class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        whyNow.signals.map((signal, i) => (
          <li class="mol-panel mol-panel-hover relative rounded-2xl p-6">
            <div
              class="mb-4 inline-flex h-8 w-8 items-center justify-center rounded-lg font-mono text-sm font-bold"
              style="background: rgba(127,232,214,0.1); color: var(--color-mint); border: 1px solid rgba(127,232,214,0.25);"
            >
              0{i + 1}
            </div>
            <h3 class="text-base font-semibold text-white">{signal.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-fg-muted)]">
              {signal.detail}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
