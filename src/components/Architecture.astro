---
import { content, type Locale } from "../i18n";
import ShapeGrid from "./ShapeGrid.astro";
import DecryptedText from "./reactbits/DecryptedText";
import SpotlightCard from "./reactbits/SpotlightCard";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].architecture;
---

<section id="architecture" class="relative isolate overflow-hidden border-y border-[color:var(--color-ink-border)]/50 py-24 sm:py-32">
  <ShapeGrid class="-z-10 opacity-60" />

  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <span class="mol-eyebrow">{c.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        <DecryptedText client:visible text={c.title} speed={40} className="font-bold" />
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {c.description}
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3" data-reveal="stagger">
      {
        c.scopes.map((scope, i) => (
          <div style={`--i: ${i}`}>
            <SpotlightCard client:visible className="mol-panel mol-panel-hover overflow-hidden rounded-2xl h-full" spotlightColor={`${scope.accent}22`}>
              <div class="h-1" style={`background: linear-gradient(90deg, ${scope.accent}, transparent);`} />
              <div class="p-5 sm:p-7">
                <div class="font-mono text-xs font-bold tracking-[0.2em]" style={`color: ${scope.accent};`}>
                  {scope.name}
                </div>
                <h3 class="mt-3 text-lg font-semibold text-white">{scope.summary}</h3>
                <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-fg-muted)]">
                  {scope.detail}
                </p>
              </div>
            </SpotlightCard>
          </div>
        ))
      }
    </div>

    <div class="mol-panel mt-10 rounded-2xl p-5 sm:p-8 lg:p-10" data-reveal>
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between lg:gap-8">
        <div class="max-w-xl">
          <h3 class="text-xl font-semibold text-white sm:text-2xl">
            {c.hermesTitle}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-fg-muted)] sm:text-base">
            {c.hermesSubtitle}
          </p>
        </div>
        <ol class="grid flex-1 gap-4 sm:grid-cols-3">
          {
            c.hermesSteps.map((step, i) => (
              <li class="rounded-xl border border-[color:var(--color-ink-border-strong)] bg-[color:var(--color-ink-soft)]/40 p-4">
                <div class="font-mono text-xs font-bold" style="color: var(--color-mint);">
                  {c.scopeLabel} {i + 1}
                </div>
                <p class="mt-2 text-sm text-white">{step}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <div class="mt-12" data-reveal>
      <h3 class="text-center font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-fg-dim)]">
        {c.outcomesTitle}
      </h3>
      <ul class="mt-6 grid gap-x-8 gap-y-3 sm:grid-cols-2">
        {
          c.outcomes.map((outcome) => (
            <li class="flex items-center gap-3 text-sm text-[color:var(--color-fg)]">
              <span
                class="h-1.5 w-1.5 flex-shrink-0 rounded-full"
                style="background: var(--color-mint); box-shadow: 0 0 8px var(--color-mint);"
                aria-hidden="true"
              />
              {outcome}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mol-flywheel mt-14" data-reveal>
      <h3 class="text-center font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-fg-dim)]">
        {c.flywheelTitle}
      </h3>
      <ol class="mol-flywheel-steps mt-8">
        {
          c.flywheelSteps.map((step, i) => (
            <li class="mol-flywheel-step">
              <span class="mol-flywheel-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="mol-flywheel-label">{step.label}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
