---
import { content, type Locale } from "../i18n";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].creatorCta;
---

<section id="creators" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <span class="mol-eyebrow">{c.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {c.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {c.subtitle}
      </p>
    </div>

    <ol class="mt-16 grid gap-6 md:grid-cols-3" data-reveal="stagger">
      {
        c.steps.map((step, i) => (
          <li class="mol-panel rounded-2xl p-7" style={`--i: ${i}`}>
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-xs font-semibold tracking-[0.2em] text-[color:var(--color-mint)]">
                {step.number}
              </span>
              <h3 class="text-base font-semibold text-white">{step.title}</h3>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-fg-muted)]">
              {step.description}
            </p>
          </li>
        ))
      }
    </ol>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3" data-reveal>
      <a
        href={c.primaryCta.href}
        class="inline-flex items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold text-[color:var(--color-bg)] transition-opacity hover:opacity-90"
        style="background: var(--color-mint);"
      >
        {c.primaryCta.label}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={c.secondaryCta.href}
        class="inline-flex items-center gap-2 rounded-md border border-[color:var(--color-ink-border-strong)] bg-transparent px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-[color:var(--color-ink-soft)]/50"
      >
        {c.secondaryCta.label}
      </a>
    </div>
  </div>
</section>
