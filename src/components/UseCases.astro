---
import { useCases } from "../data/content";
---

<section id="use-cases" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="mol-eyebrow">{useCases.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {useCases.title}
      </h2>
      <p class="mt-5 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {useCases.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {
        useCases.items.map((item) => (
          <article class="mol-panel mol-panel-hover rounded-2xl p-8">
            <div class="mb-4 flex items-center justify-between">
              <span
                class="rounded-md px-2.5 py-1 font-mono text-xs font-semibold tracking-wider uppercase"
                style="background: rgba(127,232,214,0.08); color: var(--color-mint); border: 1px solid rgba(127,232,214,0.2);"
              >
                {item.tag}
              </span>
            </div>
            <h3 class="text-xl font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-fg-muted)]">
              {item.description}
            </p>
            <ul class="mt-6 space-y-2.5">
              {
                item.bullets.map((bullet) => (
                  <li class="flex items-start gap-2.5 text-sm text-[color:var(--color-fg)]">
                    <svg
                      class="mt-0.5 flex-shrink-0"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      style="color: var(--color-mint);"
                      aria-hidden="true"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
