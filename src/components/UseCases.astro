---
import { content, type Locale } from "../i18n";
interface Props { locale: Locale }
const { locale } = Astro.props;
const c = content[locale].useCases;
const rotating = c.rotatingTexts.join("|");
---

<section id="use-cases" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <span class="mol-eyebrow">{c.eyebrow}</span>
      <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {c.titleLead}
        <span class="mol-rotator mt-4 block sm:mt-5" data-rotate={rotating}>
          {c.rotatingTexts[0]}
        </span>
      </h2>
      <p class="mt-6 text-pretty text-base text-[color:var(--color-fg-muted)] sm:text-lg">
        {c.subtitle}
      </p>
    </div>

    <div data-tabs>
      <div class="mt-14 flex justify-center" data-reveal>
        <div class="mol-tabs" role="tablist">
          {
            c.items.map((item, i) => (
              <button
                type="button"
                role="tab"
                class="mol-tab"
                data-tab={item.key}
                data-active={i === 0 ? "" : undefined}
                aria-selected={i === 0 ? "true" : "false"}
              >
                {item.tag}
              </button>
            ))
          }
        </div>
      </div>

      <div class="mt-10">
        {
          c.items.map((item, i) => (
            <div
              class="mol-tab-panel"
              data-panel={item.key}
              data-active={i === 0 ? "" : undefined}
              hidden={i !== 0}
            >
            <article class="mol-panel rounded-2xl p-8 sm:p-10">
              <div class="grid gap-8 lg:grid-cols-[1.2fr_1fr] lg:items-start">
                <div>
                  <div class="flex flex-wrap gap-2">
                    {
                      item.capabilities.map((cap) => (
                        <span
                          class="rounded-md border border-[color:var(--color-ink-border-strong)] bg-[color:var(--color-ink-soft)]/60 px-2.5 py-1 font-mono text-xs text-[color:var(--color-mint)]"
                        >
                          {cap}
                        </span>
                      ))
                    }
                  </div>
                  <h3 class="mt-5 text-2xl font-semibold text-white sm:text-3xl">
                    {item.title}
                  </h3>
                  <p class="mt-4 text-base leading-relaxed text-[color:var(--color-fg-muted)]">
                    {item.description}
                  </p>
                  <ul class="mt-6 space-y-2.5">
                    {
                      item.bullets.map((bullet) => (
                        <li class="flex items-start gap-2.5 text-sm text-[color:var(--color-fg)]">
                          <svg
                            class="mt-0.5 flex-shrink-0"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="color: var(--color-mint);"
                            aria-hidden="true"
                          >
                            <path d="M20 6L9 17l-5-5" />
                          </svg>
                          <span>{bullet}</span>
                        </li>
                      ))
                    }
                  </ul>
                </div>

                <div class="relative rounded-xl border border-[color:var(--color-ink-border)] bg-[color:var(--color-ink-soft)]/60 p-1 overflow-hidden">
                  <div class="flex items-center gap-1.5 border-b border-[color:var(--color-ink-border)] px-3 py-2">
                    <span class="h-2 w-2 rounded-full bg-[#ff5f56]" />
                    <span class="h-2 w-2 rounded-full bg-[#ffbd2e]" />
                    <span class="h-2 w-2 rounded-full bg-[#27c93f]" />
                    <span class="ml-2 font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-fg-dim)]">
                      workspace.yml
                    </span>
                  </div>
                  <pre class="overflow-x-auto p-4 font-mono text-[11px] leading-[1.65] text-[color:var(--color-fg)]"><code>{`workspace:
  id: ${item.key}
  role: ${item.tag.toLowerCase().replace(/\s+/g, "-")}
  runtime: ${item.capabilities[0]}
  memory:
    scope: [LOCAL, TEAM]
    awareness: on
    hermes: on
  governance:
    rbac: enforced
    audit: jsonl
  adapters:
${item.capabilities.map((cap) => `    - ${cap}`).join("\n")}`}</code></pre>
                </div>
              </div>
            </article>
          </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
