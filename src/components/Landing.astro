  :root[data-theme] .v2-compare-head .is-us { color: var(--accent); }
  :root[data-theme] .v2-compare-row > div { padding: 14px 18px; font-size: 13.5px; color: var(--ink); }
  :root[data-theme] .v2-compare-row .val { text-align: center; font-size: 13px; }
  /* Persistent column band on the Molecule (us) column. Without this,
     the only orientation cue across body rows is the row-hover sweep —
     so a static reader has no fast way to scan "what does Molecule do
     here" down the table. The 2nd grid cell maps to the Molecule
     column (capability is 1st, then four vendor columns). The band
     uses a very low accent mix so it reads as a region, not a button,
     and the existing row-hover gradient + .is-us:nth-child(2) hover
     boost cleanly stack on top. Header row keeps its own bgInk
     background — explicitly excluding .v2-compare-head here ensures
     the header's tint is unchanged. */
  :root[data-theme] .v2-compare-row:not(.v2-compare-head) > div:nth-child(2) {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }
  :root[data-theme] .v2-compare-row .ok { color: var(--good); font-weight: 600; }
  :root[data-theme] .v2-compare-row .no { color: var(--inkSoft); }
  :root[data-theme] .v2-compare-row .partial { color: var(--warm); font-family: ui-monospace, "JetBrains Mono", monospace; }
  :root[data-theme] .v2-compare-row[data-sweep] {
    background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 30%);
  }
  /* Scanning a 5-column matrix row-by-row is the standard
     investor-due-diligence motion. Highlight the row under the
     cursor so the reader's eye doesn't lose its place when
     comparing values across columns. The .is-us column (Molecule's
     own values) gets a stronger accent tint so the win cells stand
     out when the user is mid-scan. */
  :root[data-theme] .v2-compare-row:not(.v2-compare-head):hover {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent) 10%, transparent) 0%,
      color-mix(in srgb, var(--accent) 4%, transparent) 100%
    );
  }
  /* The Molecule (us) column is the second grid cell — capability is
     first, then the four vendor columns. Make the us-cell pop on
     hover so the answer reading "what does Molecule do for this
     capability" lands fast. */
  :root[data-theme] .v2-compare-row:not(.v2-compare-head):hover > div:nth-child(2) {
    color: var(--accent);
    font-weight: 700;
