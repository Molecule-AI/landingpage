  :root[data-theme] .v2-yaml-chrome .dots i:nth-child(2) { background: #febc2e; }
  :root[data-theme] .v2-yaml-chrome .dots i:nth-child(3) { background: #28c840; }
  :root[data-theme] .v2-yaml pre { margin: 0; white-space: pre; min-height: 280px; font-family: inherit; }
  :root[data-theme] .v2-yaml .caret {
