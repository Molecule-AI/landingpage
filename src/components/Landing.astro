  /* Logo strip */
  :root[data-theme] .v2-logo-strip { padding: 24px 0; background: var(--bgInk); overflow: hidden; }
  :root[data-theme] .v2-logo-eyebrow {
    padding: 0 32px 12px;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--inkSoft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  :root[data-theme] .v2-marquee {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  :root[data-theme] .v2-marquee-track {
    display: flex;
    gap: 56px;
    width: fit-content;
    animation: v2-marquee 48s linear infinite;
  }
  /* Pause the runtime marquee on hover/focus so a curious viewer can
     read a specific runtime name without it scrolling away. Scoped to
     the marquee container so a stray hover anywhere in the strip is
     enough — the user doesn't need to land precisely on a moving item. */
  :root[data-theme] .v2-marquee:hover .v2-marquee-track,
  :root[data-theme] .v2-marquee:focus-within .v2-marquee-track {
    animation-play-state: paused;
  }
  @keyframes v2-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 28px)); }
  }
  :root[data-theme] .v2-marquee-item {
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 16px;
    color: var(--inkMid);
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: color 0.18s ease, transform 0.18s ease;
  }
  :root[data-theme] .v2-marquee:hover .v2-marquee-item { color: var(--ink); }
  /* Cursor + lift the specific item the user is pointing at — the
     marquee is paused on hover (PR #85) so this lets the user clearly
     identify which runtime they'll click through to. */
  :root[data-theme] .v2-marquee-item:hover {
    color: var(--accent);
    transform: translateY(-1px);
  }
  :root[data-theme] .v2-marquee-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }
  /* When hovering a specific runtime tile, brighten its accent dot to
     full opacity and start the v2-pulse halo. The marquee already
     pauses on hover (#85) and the label tints accent (#104); the
     dot pulse completes the "this is the active item" cue. */
  :root[data-theme] .v2-marquee-item:hover .dot,
  :root[data-theme] .v2-marquee-item:focus-visible .dot {
    opacity: 1;
    animation: v2-pulse 1.4s ease-out infinite;
  }

  /* Cards */
  :root[data-theme] .v2-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  :root[data-theme] .v2-grid-tight { gap: 14px; }
  :root[data-theme] .v2-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    /* perspective on the grid so each child card can rotateX/Y on
       cursor (same TiltedCard pattern as #106 + #107). The marketplace
       tier-card grid keeps its narrower perspective on
       .v2-tier-card-link for the existing tier-card tilt — that inner
       perspective scope wins for those cards; the outer 1100px applies
       to scope / adapter / creator children. */
    perspective: 1100px;
  }
  :root[data-theme] .v2-card {
    padding: 22px;
    background: var(--bgElev);
    border: 1px solid var(--line);
    border-radius: 8px;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  /* .v2-card-hover composes with SpotlightCard's mouse-tracked spotlight:
     the SpotlightCard JS draws a cursor-following highlight, but the card
     itself has no onclick — `cursor: pointer` signals interactivity for
     the hover/spotlight gesture without claiming a click target. The
     :active scale matches the .v2-btn pattern from PR #133 (scale 0.985
     + tight 0.06s transition) so press feedback is consistent across
     cards and buttons. transition-delay: 0 keeps the lift snappy in case
     a parent stagger sets a delay. */
  :root[data-theme] .v2-card-hover {
    cursor: pointer;
  }
  :root[data-theme] .v2-card-hover:hover {
    transform: translateY(-3px);
    border-color: var(--ink);
    box-shadow: 0 16px 40px -20px rgba(var(--shadow-rgb), 0.18);
    transition-delay: 0s;
  }
  :root[data-theme] .v2-card-hover:active {
    transform: translateY(-2px) scale(0.985);
    transition-duration: 0.06s;
  }
  :root[data-theme] .v2-card-warm:hover {
    transform: translateY(-2px);
    border-color: var(--warm);
    transition-delay: 0s;
  }
  :root[data-theme] .v2-card-warm:active {
    transform: translateY(-1px) scale(0.985);
    transition-duration: 0.06s;
  }
  /* Reduced-motion: keep border-color and shadow affordances but drop
     the transform animation on both hover and press so the card neither
     lifts nor scales for users who opt out of motion. */
  @media (prefers-reduced-motion: reduce) {
    :root[data-theme] .v2-card-hover:hover,
    :root[data-theme] .v2-card-hover:active,
    :root[data-theme] .v2-card-warm:hover,
    :root[data-theme] .v2-card-warm:active {
      transform: none;
    }
  }
  /* Why-now reason icons. Soft accent-tinted square anchors the card
     visually and provides a fast skim signal (bars / nodes / shield /
     swap) so investors can read the four-shifts story even before
     parsing the title. */
  :root[data-theme] .v2-card-icon {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent);
    margin-bottom: 14px;
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
      background 0.25s ease;
  }
  :root[data-theme] .v2-card-hover:hover .v2-card-icon,
  :root[data-theme] .v2-adapter-card:hover .v2-card-icon {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--accent) 22%, transparent);
  }
  /* Warm-themed icon variant for the Pillars cards. Same square + lift
     gesture as the cyan .v2-card-icon, but tinted on --warm to match
     the v2-card-warm spotlight + keynum color. */
  :root[data-theme] .v2-card-icon-warm {
    background: color-mix(in srgb, var(--warm) 14%, transparent);
    color: var(--warm);
  }
  :root[data-theme] .v2-card-warm:hover .v2-card-icon-warm {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--warm) 22%, transparent);
  }
  :root[data-theme] .v2-keynum {
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--accent);
    margin-bottom: 14px;
    letter-spacing: 0.08em;
    display: inline-block;
    transform-origin: left center;
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
      letter-spacing 0.25s ease;
  }
  /* Same family of polish as the Creator step number (#89) — the
     parent card lift on :hover triggers a small slide+tracking-expand
     on the keynum so the eye is anchored to the section's number. */
  :root[data-theme] .v2-card-hover:hover .v2-keynum,
  :root[data-theme] .v2-card-warm:hover .v2-keynum {
    transform: translateX(2px);
    letter-spacing: 0.14em;
  }
  :root[data-theme] .v2-keynum-warm { color: var(--warm); margin-bottom: 12px; }
  :root[data-theme] .v2-card-title { margin: 0 0 8px; font-size: 16px; font-weight: 600; letter-spacing: -0.01em; }
  :root[data-theme] .v2-card-title-sm { font-size: 14.5px; margin-bottom: 6px; }
  :root[data-theme] .v2-card-body { margin: 0; font-size: 13.5px; color: var(--inkMid); line-height: 1.55; }
  :root[data-theme] .v2-card-body-sm { font-size: 12.5px; }

  /* Use cases */
  :root[data-theme] .v2-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
