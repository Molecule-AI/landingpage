  @keyframes v2-caret { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }

  /* Use-case agent topology diagram. Replaces the previous YAML pre block
     with an animated SVG so investors / non-engineers see the org shape
     instead of a config dump. The "show YAML" toggle keeps the original
     view available for technical readers. */
  :root[data-theme] .v2-usecase-diagram {
    position: relative;
    background: var(--bgElev);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 16px 18px 14px;
    display: flex;
    flex-direction: column;
    min-height: 360px;
    overflow: hidden;
  }
  :root[data-theme] .v2-usecase-diagram-chrome {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :root[data-theme] .v2-usecase-diagram-actions {
    display: inline-flex;
    gap: 6px;
  }
  :root[data-theme] .v2-usecase-diagram-toggle {
    background: transparent;
    border: 1px solid var(--line);
    color: var(--inkMid);
    border-radius: 999px;
