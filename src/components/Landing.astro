  /* Root inner circle (CEO Coordinator) — set once with `ink` color. */
  :root[data-theme] svg[data-topology] .v2-topo-inner-root {
    fill: var(--ink);
  }
  /* Non-leaf mid inner circles (Engineering / Compliance / Finance). */
  :root[data-theme] svg[data-topology] .v2-topo-inner-mid {
    fill: var(--inkMid);
  }
  :root[data-theme] .v2-hero-card-chrome {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--inkSoft);
