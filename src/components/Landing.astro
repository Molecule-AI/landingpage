  /* Mirror of the header .v2-brand hover micro-anim (PR #147): a small
     rotation + slight scale on the 3-node mark when the user hovers the
     footer brand. The footer brand is a non-link <div>, so the hover
     trigger is the wrapper itself; pointer-events: auto on the SVG keeps
     the hit-test reliable across themes. Honors prefers-reduced-motion. */
  :root[data-theme] .v2-footer-brand svg {
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
      color 0.25s ease;
    transform-origin: 50% 50%;
    will-change: transform;
    pointer-events: auto;
  }
  :root[data-theme] .v2-footer-brand:hover svg {
    transform: rotate(8deg) scale(1.06);
