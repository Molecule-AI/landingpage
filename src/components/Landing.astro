  // tier cards are smaller + clickable so 6° feels right; the ship
  // cards are larger + denser so 4° is plenty.
  if (!prefersReducedMotion) {
    type TiltTarget = { wrapper: HTMLElement; card: HTMLElement; maxDeg: number };
    const tilters: TiltTarget[] = [];
    document.querySelectorAll<HTMLElement>(".v2-tier-card-link").forEach((w) => {
