  }
  :root[data-theme] .v2-deploy-step em { color: var(--inkMid); margin-left: 6px; font-style: normal; }
  :root[data-theme] .v2-yaml {
    background: #0b0d11;
    color: #e8e9eb;
    border: 1px solid var(--line);
