---
import { landingContent, type LandingContent } from "../data/landing";
import ThemeToggle from "./ThemeToggle.tsx";
import BlurText from "./reactbits/BlurText";
import SpotlightCard from "./reactbits/SpotlightCard";

interface Props {
  locale: "en" | "zh";
}

const { locale } = Astro.props;
const c: LandingContent = landingContent[locale];

// Plug glyph SVGs inline so the marketplace tier cards work without a separate icon component.
const tierGlyphs: Record<string, string> = {
  plugin: `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="4" height="4" fill="currentColor"/><rect x="8" y="2" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="2" y="8" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="8" y="8" width="4" height="4" fill="currentColor"/></svg>`,
  agent: `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="7" cy="7" r="1.8" fill="currentColor"/></svg>`,
  org: `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.6" fill="currentColor"/><circle cx="3" cy="11" r="1.6" fill="currentColor"/><circle cx="11" cy="11" r="1.6" fill="currentColor"/><line x1="7" y1="4.6" x2="7" y2="7" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="3" y2="9.4" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="11" y2="9.4" stroke="currentColor" stroke-width="1.2"/></svg>`,
};
---

<header class="v2-nav">
  <div class="v2-statusbar">
    <span><i class="dot dot-good"></i>{c.statusbar.allSystems} · {c.statusbar.statusLink}</span>
    <span>{c.statusbar.phase}</span>
  </div>
  <div class="v2-nav-row">
    <a class="v2-brand" href={locale === "zh" ? "/zh/" : "/"}>
      <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="6" r="2.5" fill="currentColor" />
        <circle cx="6" cy="20" r="2.5" fill="currentColor" />
        <circle cx="22" cy="20" r="2.5" fill="currentColor" />
        <circle cx="14" cy="14" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2" />
        <line x1="14" y1="8.5" x2="14" y2="12.6" stroke="currentColor" stroke-width="1.2" />
        <line x1="8" y1="18.5" x2="12.7" y2="14.8" stroke="currentColor" stroke-width="1.2" />
        <line x1="20" y1="18.5" x2="15.3" y2="14.8" stroke="currentColor" stroke-width="1.2" />
      </svg>
      <span class="v2-brand-name">Molecule</span>
      <span class="v2-brand-tag">AI</span>
    </a>
    <nav class="v2-nav-links">
      {c.nav.links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a>
      ))}
    </nav>
    <div class="v2-nav-cta">
      <ThemeToggle client:idle />
      <a class="v2-btn v2-btn-primary" href="https://app.moleculesai.app">{c.nav.signIn}</a>
    </div>
  </div>
</header>

<main id="main">
  {/* HERO */}
  <section class="v2-section v2-hero">
    <canvas data-particle data-density="0.00006" data-line="120"></canvas>
    <div class="v2-container v2-hero-grid">
      <div>
        <div class="v2-eyebrow" data-reveal>
          <span class="dot dot-warm"></span>
          {c.hero.eyebrow}
        </div>
        <h1 class="v2-h1">
          <BlurText client:visible text={c.hero.h1Lead} delay={70} />
          <br />
          <span class="v2-h1-shimmer">{c.hero.h1Highlight}</span>
        </h1>
        <p class="v2-lede" data-reveal data-delay="160">{c.hero.lede}</p>
        <div class="v2-cta-row" data-reveal data-delay="240">
          <a class="v2-btn v2-btn-primary v2-btn-lg" href="https://github.com/Molecule-AI/molecule-monorepo" rel="noopener" target="_blank">{c.hero.primaryCta}</a>
          <a class="v2-btn v2-btn-ghost v2-btn-lg" href="https://app.moleculesai.app" rel="noopener" target="_blank">{c.hero.secondaryCta}</a>
        </div>
        <div class="v2-stat-row" data-reveal data-delay="320">
          {c.hero.stats.map((s) => (
            <div>
              <span class="v2-counter" data-counter={s.to} data-suffix={s.suffix ?? ""}>0</span>
              <em>{s.label}</em>
            </div>
          ))}
        </div>
      </div>
      <div class="v2-hero-card" data-reveal data-delay="120">
        <div class="v2-hero-card-chrome">
          <span>{c.hero.heroCardUrl}</span>
          <span><i class="dot dot-good pulsing"></i>{c.hero.heroCardA2ALabel} · <span data-a2a>42</span> {c.hero.heroCardA2ASuffix}</span>
        </div>
        <svg data-topology viewBox="0 0 560 420" width="100%" style="display:block"></svg>
      </div>
    </div>
  </section>

  {/* LOGO STRIP */}
  <section class="v2-section v2-logo-strip">
    <div class="v2-logo-eyebrow">{c.logoStrip.eyebrow}</div>
    <div class="v2-marquee">
      <div class="v2-marquee-track">
        {[...c.logoStrip.runtimes, ...c.logoStrip.runtimes].map((n) => (
          <span class="v2-marquee-item">
            <i class="dot dot-accent"></i>
            {n}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* WHY NOW */}
  <section class="v2-section">
    <div class="v2-container">
      <div class="v2-section-head">
        <div>
          <div class="v2-kicker" data-reveal>{c.whyNow.kicker}</div>
          <h2 class="v2-h2">
            <BlurText client:visible text={c.whyNow.title} delay={60} />
          </h2>
        </div>
      </div>
      <div class="v2-grid-4">
        {c.whyNow.reasons.map((r, i) => (
          <div data-reveal data-delay={i * 90}>
            <SpotlightCard client:visible className="v2-card v2-card-hover h-full" spotlightColor="rgba(127,232,214,0.14)">
              <div class="v2-keynum">{r.k}</div>
              <h3 class="v2-card-title">{r.title}</h3>
              <p class="v2-card-body">{r.body}</p>
            </SpotlightCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* USE CASES */}
  <section class="v2-section v2-section-ink">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.useCases.kicker}</div>
          <h2 class="v2-h2">{c.useCases.title}</h2>
        </div>
      </div>
      <div class="v2-tabs" data-tabs role="tablist" data-reveal data-delay="80">
        {c.useCases.cases.map((cs, i) => (
          <button
            class="v2-tab"
            data-tab={cs.id}
            data-active={i === 0 ? "true" : undefined}
            type="button"
          >
            {cs.label}
          </button>
        ))}
      </div>
      <div class="v2-usecase-grid" data-reveal data-delay="160">
        <div class="v2-usecase-meta">
          <div class="v2-kicker v2-kicker-accent" data-meta-kicker>{c.useCases.cases[0].kicker}</div>
          <h3 class="v2-usecase-h3" data-meta-label>{c.useCases.cases[0].label}</h3>
          <p class="v2-card-body">{c.useCases.intro}</p>
          <div class="v2-cmd" data-cmd>{c.useCases.cmdPrefix} ./{c.useCases.cases[0].id}.yml</div>
          <div class="v2-deploy-steps" data-deploy>
            {c.useCases.deploySteps.map((step) => (
              <div class="v2-deploy-step"><span class="check">✓</span><em>{step}</em></div>
            ))}
          </div>
        </div>
        <div class="v2-yaml">
          <div class="v2-yaml-chrome">
            <span>workspace.yml</span>
            <span class="dots"><i></i><i></i><i></i></span>
          </div>
          <pre data-yaml-target>{c.useCases.cases[0].yaml}<span class="caret"></span></pre>
        </div>
      </div>
    </div>
    {c.useCases.cases.map((cs) => (
      <script
        type="application/json"
        data-yaml={cs.id}
        set:html={JSON.stringify({
          yaml: cs.yaml,
          kicker: cs.kicker,
          label: cs.label,
          deploy: `${c.useCases.cmdPrefix} ./${cs.id}.yml`,
        })}
        is:inline
      />
    ))}
  </section>

  {/* ARCHITECTURE — three-tier memory + Hermes */}
  <section class="v2-section">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.architecture.kicker}</div>
          <h2 class="v2-h2">{c.architecture.title}</h2>
          <p class="v2-section-lede">{c.architecture.description}</p>
        </div>
      </div>
      <div class="v2-grid-3">
        {c.architecture.scopes.map((s, i) => (
          <div data-reveal data-delay={i * 90}>
            <SpotlightCard client:visible className="v2-scope-card h-full" spotlightColor="rgba(127,232,214,0.14)">
              <div class="v2-scope-head">
                <span class="v2-scope-tag">{c.architecture.scopeLabel}</span>
                <span class="v2-scope-name">{s.name}</span>
              </div>
              <h3 class="v2-scope-title">{s.summary}</h3>
              <p class="v2-card-body">{s.detail}</p>
            </SpotlightCard>
          </div>
        ))}
      </div>
      <div class="v2-hermes" data-reveal data-delay="120">
        <div class="v2-hermes-head">
          <h3 class="v2-card-title">{c.architecture.hermesTitle}</h3>
          <p class="v2-card-body">{c.architecture.hermesSubtitle}</p>
        </div>
        <ol class="v2-hermes-steps">
          {c.architecture.hermesSteps.map((step, i) => (
            <li>
              <span class="v2-hermes-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {/* ADAPTERS — runtime/model/observability cards */}
  <section id="adapters" class="v2-section v2-section-ink">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.adapters.kicker}</div>
          <h2 class="v2-h2">{c.adapters.title}</h2>
          <p class="v2-section-lede">{c.adapters.subtitle}</p>
        </div>
      </div>
      <div class="v2-grid-3">
        {c.adapters.cards.map((card, i) => (
          <div class="v2-adapter-card" data-reveal data-delay={i * 100}>
            <div class="v2-adapter-head">
              <h3 class="v2-card-title">{card.title}</h3>
              <p class="v2-adapter-headline">{card.headline}</p>
            </div>
            <p class="v2-card-body">{card.detail}</p>
            <ul class="v2-adapter-list">
              {card.items.map((item) => (
                <li><i class="dot dot-accent"></i>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* PLATFORM PILLARS */}
  <section class="v2-section">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.pillars.kicker}</div>
          <h2 class="v2-h2">{c.pillars.title}</h2>
        </div>
      </div>
      <div class="v2-grid-4 v2-grid-tight">
        {c.pillars.items.map((p, i) => (
          <div data-reveal data-delay={(i % 4) * 70}>
            <SpotlightCard client:visible className="v2-card v2-card-warm h-full" spotlightColor="rgba(255,179,102,0.16)">
              <div class="v2-keynum v2-keynum-warm">{p.k}</div>
              <h3 class="v2-card-title v2-card-title-sm">{p.title}</h3>
              <p class="v2-card-body v2-card-body-sm">{p.body}</p>
            </SpotlightCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* WHAT SHIPS — Canvas + Platform open-core columns */}
  <section class="v2-section v2-section-ink">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.whatShips.kicker}</div>
          <h2 class="v2-h2">{c.whatShips.title}</h2>
          <p class="v2-section-lede">{c.whatShips.subtitle}</p>
        </div>
      </div>
      <div class="v2-ships-grid">
        {c.whatShips.columns.map((col, i) => (
          <div data-reveal data-delay={i * 120}>
            <SpotlightCard client:visible className="v2-ship-card" spotlightColor="rgba(127,232,214,0.16)">
              <div class="v2-ship-head">
                <span class="v2-kicker v2-kicker-accent">{col.label}</span>
                <h3 class="v2-card-title">{col.name}</h3>
                <p class="v2-ship-stack">{col.stack}</p>
              </div>
              <ul class="v2-ship-list">
                {col.items.map((item) => (
                  <li><span class="check">✓</span>{item}</li>
                ))}
              </ul>
            </SpotlightCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* MARKETPLACE PROMO */}
  <section id="marketplace" class="v2-section v2-section-ink v2-section-relative">
    <canvas data-particle data-density="0.00004" data-line="140" data-color="warm"></canvas>
    <div class="v2-container v2-section-relative">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.marketplace.kicker}</div>
          <h2 class="v2-h2">{c.marketplace.title}</h2>
        </div>
        <a class="v2-btn v2-btn-primary" href="https://market.moleculesai.app"
          >{c.marketplace.openMarketplace}</a
        >
      </div>
      <div class="v2-grid-3">
        {c.marketplace.tiers.map((tr, i) => (
          <a class="v2-tier-card" data-reveal data-delay={i * 120} href="https://market.moleculesai.app">
            <div class="v2-tier-head">
              <div class="v2-tier-glyph" set:html={tierGlyphs[tr.glyph]} />
              <div>
                <span class="v2-tier-tag">{tr.tag}</span>
                <h3 class="v2-tier-title">{tr.title}</h3>
              </div>
            </div>
            <p class="v2-card-body">{tr.desc}</p>
            <div class="v2-tier-foot">
              <span>{tr.count}</span><span class="browse">{c.marketplace.browse}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* CREATOR — Build / List / Earn */}
  <section class="v2-section">
    <div class="v2-container">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.creator.kicker}</div>
          <h2 class="v2-h2">{c.creator.title}</h2>
          <p class="v2-section-lede">{c.creator.subtitle}</p>
        </div>
      </div>
      <div class="v2-grid-3">
        {c.creator.steps.map((step, i) => (
          <div data-reveal data-delay={i * 100}>
            <SpotlightCard client:visible className="v2-creator-step h-full" spotlightColor="rgba(127,232,214,0.14)">
              <div class="v2-creator-num">{step.number}</div>
              <h3 class="v2-card-title">{step.title}</h3>
              <p class="v2-card-body">{step.description}</p>
            </SpotlightCard>
          </div>
        ))}
      </div>
      <div class="v2-cta-row v2-cta-center" data-reveal data-delay="300">
        <a class="v2-btn v2-btn-primary" href={c.creator.primaryCta.href}>{c.creator.primaryCta.label}</a>
        <a class="v2-btn v2-btn-ghost" href={c.creator.secondaryCta.href}>{c.creator.secondaryCta.label}</a>
      </div>
    </div>
  </section>

  {/* COMPARISON */}
  <section class="v2-section">
    <div class="v2-container v2-narrow">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.comparison.kicker}</div>
          <h2 class="v2-h2">{c.comparison.title}</h2>
        </div>
      </div>
      <div class="v2-compare" data-reveal>
        <div class="v2-compare-row v2-compare-head">
          <div>{c.comparison.capability}</div>
          {c.comparison.cols.map((col, i) => (
            <div class={i === 0 ? "is-us" : ""}>{col}</div>
          ))}
        </div>
        {c.comparison.rows.map((row) => (
          <div class="v2-compare-row" data-compare-row>
            <div>{row[0]}</div>
            {row.slice(1).map((v) => (
              <div class={`val ${v === "✓" ? "ok" : v === "—" ? "no" : "partial"}`}>{v}</div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="v2-section v2-section-ink">
    <div class="v2-container v2-narrowest">
      <div class="v2-section-head" data-reveal>
        <div>
          <div class="v2-kicker">{c.faq.kicker}</div>
          <h2 class="v2-h2">{c.faq.title}</h2>
        </div>
      </div>
      <div class="v2-faq">
        {c.faq.items.map(([q, a], i) => (
          <details class="v2-faq-item" open={i === 0}>
            <summary>
              <span>{q}</span>
              <span class="plus">+</span>
            </summary>
            <div class="v2-faq-a">{a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* FINAL CTA */}
  <section class="v2-section v2-section-relative v2-final">
    <canvas data-particle data-density="0.00009" data-line="130"></canvas>
    <div class="v2-container v2-narrowest v2-section-relative" style="text-align:center">
      <h2 class="v2-final-h2" data-reveal>
        {c.final.h2Lead}<br />
        <span class="v2-h1-shimmer">{c.final.h2Highlight}</span>
      </h2>
      <p class="v2-final-p" data-reveal data-delay="100">{c.final.lede}</p>
      <div class="v2-cta-row v2-cta-center" data-reveal data-delay="180">
        <a class="v2-btn v2-btn-primary v2-btn-lg" href="https://market.moleculesai.app"
          >{c.final.primaryCta}</a
        >
        <a class="v2-btn v2-btn-ghost v2-btn-lg" href="https://app.moleculesai.app"
          >{c.final.secondaryCta}</a
        >
      </div>
    </div>
  </section>
</main>

{/* FOOTER */}
<footer class="v2-footer">
  <div class="v2-container v2-footer-grid">
    <div>
      <div class="v2-footer-brand">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="6" r="2.5" fill="currentColor" />
          <circle cx="6" cy="20" r="2.5" fill="currentColor" />
          <circle cx="22" cy="20" r="2.5" fill="currentColor" />
          <circle cx="14" cy="14" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2" />
        </svg>
        <span>Molecule AI</span>
      </div>
      <p>{c.footer.tagline}</p>
    </div>
    {c.footer.sections.map((sec) => (
      <div>
        <div class="v2-footer-h">{sec.heading}</div>
        {sec.items.map((it) => (
          <a>{it}</a>
        ))}
      </div>
    ))}
  </div>
  <div class="v2-container v2-footer-bottom">
    <span>{c.footer.legal}</span>
    <span>{c.footer.version}</span>
  </div>
</footer>

<style is:global>
  /* Token values per theme. Selectors are gated on :root[data-theme]
   * (matches <html>) so the cascade resolves against the attribute
   * the boot script in Layout.astro stamps synchronously — before
   * <body> exists. Stamping body would FOUC the first paint frame
   * because body wouldn't carry the resolved theme until
   * DOMContentLoaded. Shadow components use --shadow-rgb so elevation
   * darkens correctly on cream paper but shifts to true black on
   * deep ink.
   */
  :root[data-theme="light"] {
    --bg: #fafaf7;
    --bgElev: #ffffff;
    --bgInk: #f3f1ec;
    --line: #e6e2d8;
    --lineSoft: #efece4;
    --ink: #15181c;
    --inkMid: #5a5e66;
    --inkSoft: #8b8e95;
    --accent: #3b5bdb;
    --accentInk: #1a2f99;
    --warm: #c0532b;
    --good: #2f7a4d;
    --shadow-rgb: 21, 24, 28;
    --accent-fg: #ffffff;     /* text on --accent surfaces */
  }
  :root[data-theme="dark"] {
    --bg: #050912;
    --bgElev: #0d1729;
    --bgInk: #0a1120;
    --line: #13263f;
    --lineSoft: #1c3350;
    --ink: #e5f0ff;
    --inkMid: #8fa3bf;
    --inkSoft: #5f7691;
    --accent: #7fe8d6;       /* mint accent in dark */
    --accentInk: #a8f0e1;
    --warm: #ffd166;
    --good: #6af0b8;
    --shadow-rgb: 0, 0, 0;
    --accent-fg: #04121a;     /* dark text on pale-mint accent */
  }
  :root[data-theme] body {
    margin: 0;
    font-family: "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    background: var(--bg);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    background-image: none;
  }
  :root[data-theme] *,
  :root[data-theme] *::before,
  :root[data-theme] *::after {
    box-sizing: border-box;
  }
  :root[data-theme] .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    margin-right: 6px;
  }
  :root[data-theme] .dot-good { background: var(--good); color: var(--good); }
  :root[data-theme] .dot-warm { background: var(--warm); color: var(--warm); }
  :root[data-theme] .dot-accent { background: var(--accent); color: var(--accent); opacity: 0.5; }
