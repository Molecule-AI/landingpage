    cursor: pointer;
    /* Compose the existing translateY(-4px) hover-lift with the
       cursor-tracked rotateX/rotateY. CSS vars resolve to 0deg when
       the cursor is off the card so the card rests flat. */
    transform: translateY(0) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transform-style: preserve-3d;
    transition: all 0.18s cubic-bezier(0.2, 0.7, 0.2, 1);
    text-decoration: none;
    color: inherit;
    height: 100%;
