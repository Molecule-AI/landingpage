---
import { landingContent, type LandingContent } from "../data/landing";
import ThemeToggle from "./ThemeToggle.tsx";
import LocaleDropdown from "./LocaleDropdown.astro";
import BlurText from "./reactbits/BlurText";
import ShinyText from "./reactbits/ShinyText";
import SpotlightCard from "./reactbits/SpotlightCard";
import DecryptedText from "./reactbits/DecryptedText";
import SplitText from "./reactbits/SplitText";

interface Props {
  locale: "en" | "zh" | "fr" | "ja" | "es";
}

const { locale } = Astro.props;
const c: LandingContent = landingContent[locale];

// Why-now reason icons. Indexed positionally (0..3) so the data file
// stays free of icon-implementation details. Designed at 14×14 viewBox
// to match tierGlyphs; rendered at 22×22 inside a soft accent-tinted
// surface above the keynum. currentColor inherits from the .v2-card-icon
// CSS rule so dark/light theme reactivity works without inline fills.
const whyNowGlyphs: ReadonlyArray<string> = [
  // 01 — agent count exploding (ascending bars)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="2" y="9" width="2" height="3" fill="currentColor"/><rect x="6" y="6" width="2" height="6" fill="currentColor"/><rect x="10" y="3" width="2" height="9" fill="currentColor"/></svg>`,
  // 02 — A2A / MCP standards (two nodes + bridge)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="3.2" cy="7" r="1.6" fill="currentColor"/><circle cx="10.8" cy="7" r="1.6" fill="currentColor"/><path d="M5 7 L9 7" stroke="currentColor" stroke-width="1.2"/><path d="M7 5 L7 9" stroke="currentColor" stroke-width="1.2" opacity="0.45"/></svg>`,
  // 03 — governance / buying gate (shield + check)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M7 1.6 L11.6 3.4 L11.6 7.6 Q11.6 10.4 7 12.4 Q2.4 10.4 2.4 7.6 L2.4 3.4 Z" stroke="currentColor" stroke-width="1.1" fill="none"/><path d="M4.6 7.2 L6.4 8.8 L9.4 5.4" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  // 04 — runtimes commoditize (swap arrows)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M2.5 4.5 L11 4.5 L8.5 2.4 M11.5 9.5 L3 9.5 L5.5 11.6" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
];

// Pillar icons — 8 small glyphs matching the 8 PRD pillars (F1..F8).
// Same 14×14 viewBox + currentColor pattern as whyNowGlyphs, rendered
// inside .v2-card-icon-warm (warm-tinted square). Indexed positionally
// so landing.ts stays free of icon implementation details.
const pillarGlyphs: ReadonlyArray<string> = [
  // F1 Role > Task — small org-chart (1 parent → 2 children)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.4" fill="currentColor"/><circle cx="3.5" cy="11" r="1.4" fill="currentColor"/><circle cx="10.5" cy="11" r="1.4" fill="currentColor"/><path d="M7 4.4 L7 6.5 L3.5 9.5 M7 6.5 L10.5 9.5" stroke="currentColor" stroke-width="1.1" fill="none"/></svg>`,
  // F2 Recursive teams — branching tree (deeper than F1)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="2.5" r="1.2" fill="currentColor"/><circle cx="3.5" cy="7" r="1.2" fill="currentColor"/><circle cx="10.5" cy="7" r="1.2" fill="currentColor"/><circle cx="2" cy="11.5" r="1" fill="currentColor"/><circle cx="5" cy="11.5" r="1" fill="currentColor"/><circle cx="9" cy="11.5" r="1" fill="currentColor"/><circle cx="12" cy="11.5" r="1" fill="currentColor"/><path d="M7 3.7 L3.5 5.8 M7 3.7 L10.5 5.8 M3.5 8.2 L2 10.5 M3.5 8.2 L5 10.5 M10.5 8.2 L9 10.5 M10.5 8.2 L12 10.5" stroke="currentColor" stroke-width="0.9" fill="none"/></svg>`,
  // F3 Org = Topology — triangle of connected nodes
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.5" fill="currentColor"/><circle cx="3" cy="11" r="1.5" fill="currentColor"/><circle cx="11" cy="11" r="1.5" fill="currentColor"/><path d="M7 4.5 L3 9.5 M7 4.5 L11 9.5 M4.5 11 L9.5 11" stroke="currentColor" stroke-width="1.1" fill="none"/></svg>`,
  // F4 Distributed A2A — 4-way arrows from center
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="1.4" fill="currentColor"/><path d="M7 5 L7 2 M9 7 L12 7 M7 9 L7 12 M5 7 L2 7" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/><path d="M5.8 3.2 L7 2 L8.2 3.2 M10.8 5.8 L12 7 L10.8 8.2 M5.8 10.8 L7 12 L8.2 10.8 M3.2 5.8 L2 7 L3.2 8.2" stroke="currentColor" stroke-width="1.1" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  // F5 4-layer security — 4 stacked layers (rectangles)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="10" height="2" rx="0.5" stroke="currentColor" stroke-width="0.8" fill="currentColor" fill-opacity="0.85"/><rect x="2" y="5" width="10" height="2" rx="0.5" stroke="currentColor" stroke-width="0.8" fill="currentColor" fill-opacity="0.55"/><rect x="2" y="8" width="10" height="2" rx="0.5" stroke="currentColor" stroke-width="0.8" fill="currentColor" fill-opacity="0.35"/><rect x="2" y="11" width="10" height="1.6" rx="0.5" stroke="currentColor" stroke-width="0.8" fill="none"/></svg>`,
  // F6 Tiered HITL — stairs (3 ascending steps)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M2 12 L2 8 L6 8 L6 5 L10 5 L10 2 L12 2" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  // F7 Cross-workspace traces — 2 timelines + connecting span
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M2 4 L12 4" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="4" cy="4" r="0.9" fill="currentColor"/><circle cx="8" cy="4" r="0.9" fill="currentColor"/><path d="M2 10 L12 10" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="6" cy="10" r="0.9" fill="currentColor"/><circle cx="10" cy="10" r="0.9" fill="currentColor"/><path d="M8 4.9 L6 9.1" stroke="currentColor" stroke-width="0.9" stroke-dasharray="1.5 1.5"/></svg>`,
  // F8 3-layer Marketplace — stacked cards (Plugin / Agent / Org)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="3.4" y="2" width="7.2" height="2.4" rx="0.6" stroke="currentColor" stroke-width="0.9" fill="currentColor" fill-opacity="0.85"/><rect x="2.4" y="5.8" width="9.2" height="2.4" rx="0.6" stroke="currentColor" stroke-width="0.9" fill="currentColor" fill-opacity="0.55"/><rect x="1.4" y="9.6" width="11.2" height="2.4" rx="0.6" stroke="currentColor" stroke-width="0.9" fill="currentColor" fill-opacity="0.3"/></svg>`,
];

// Adapter card icons — 3 glyphs for Model providers / Runtime adapters /
// Tools-Eval-Observability. Same 14×14 currentColor pattern as
// whyNowGlyphs and pillarGlyphs. Indexed positionally.
const adapterGlyphs: ReadonlyArray<string> = [
  // 0 Model providers — sparkle (model creativity)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M7 1.5 L7.9 5.1 L11.5 6 L7.9 6.9 L7 10.5 L6.1 6.9 L2.5 6 L6.1 5.1 Z" fill="currentColor" opacity="0.85"/><path d="M11 11 L11.5 12.5 L13 13 L11.5 13.5" stroke="currentColor" stroke-width="0.9" fill="none" opacity="0.55"/></svg>`,
  // 1 Runtime adapters — gear / cog (engine swap)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="2.4" stroke="currentColor" stroke-width="1.1" fill="none"/><circle cx="7" cy="7" r="0.9" fill="currentColor"/><path d="M7 1.5 L7 3.4 M7 10.6 L7 12.5 M12.5 7 L10.6 7 M3.4 7 L1.5 7 M11.1 2.9 L9.7 4.3 M4.3 9.7 L2.9 11.1 M11.1 11.1 L9.7 9.7 M4.3 4.3 L2.9 2.9" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>`,
  // 2 Observability — eye + scan line (telemetry)
  `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><path d="M1.5 7 Q4 3 7 3 Q10 3 12.5 7 Q10 11 7 11 Q4 11 1.5 7 Z" stroke="currentColor" stroke-width="1.1" fill="none"/><circle cx="7" cy="7" r="1.6" fill="currentColor"/><path d="M2 12 L4.5 12" stroke="currentColor" stroke-width="0.9" opacity="0.55"/><path d="M5.5 12 L7 12" stroke="currentColor" stroke-width="0.9" opacity="0.55"/><path d="M8 12 L11.5 12" stroke="currentColor" stroke-width="0.9" opacity="0.55"/></svg>`,
];

// Plug glyph SVGs inline so the marketplace tier cards work without a separate icon component.
const tierGlyphs: Record<string, string> = {
  plugin: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="4" height="4" fill="currentColor"/><rect x="8" y="2" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="2" y="8" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="8" y="8" width="4" height="4" fill="currentColor"/></svg>`,
  agent: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="7" cy="7" r="1.8" fill="currentColor"/></svg>`,
  org: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.6" fill="currentColor"/><circle cx="3" cy="11" r="1.6" fill="currentColor"/><circle cx="11" cy="11" r="1.6" fill="currentColor"/><line x1="7" y1="4.6" x2="7" y2="7" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="3" y2="9.4" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="11" y2="9.4" stroke="currentColor" stroke-width="1.2"/></svg>`,
};

// Footer link destinations — one source of truth, indexed by section
// position (0=Product, 1=Marketplace, 2=Runtimes, 3=Trust) so that
// localized labels in landing.ts stay decoupled from URLs (the URL
// for "Canvas" / "画布" / "Toile" is the same regardless of locale).
//
// Why position-keyed instead of label-keyed: the section heading is
// localized — keying by English heading would silently fail for zh/fr/
// ja/es. The order of `c.footer.sections` is stable across locales by
// convention; this map mirrors that order. If a locale ever reorders
// sections, the wrong URLs would attach — but the type system would
// surface it via index drift in the test fixture.
const footerHrefs: ReadonlyArray<ReadonlyArray<string>> = [
  // Product: Canvas, Platform API, Control Plane, Customer App
  [
    "https://app.moleculesai.app",
    "https://doc.moleculesai.app",
    "https://doc.moleculesai.app/architecture/control-plane",
    "https://app.moleculesai.app",
  ],
  // Marketplace: Plugins (L1), Agents (L2), Org Bundles (L3), Publish
  [
    "https://market.moleculesai.app/?tier=L1",
    "https://market.moleculesai.app/?tier=L2",
    "https://market.moleculesai.app/?tier=L3",
    "https://doc.moleculesai.app/marketplace/publish",
  ],
  // Runtimes: LangGraph, Claude Code, CrewAI, AutoGen, +5 more
  [
    "https://doc.moleculesai.app/adapters/langgraph",
    "https://doc.moleculesai.app/adapters/claude-code",
    "https://doc.moleculesai.app/adapters/crewai",
    "https://doc.moleculesai.app/adapters/autogen",
    "https://doc.moleculesai.app/adapters",
  ],
  // Trust: EU AI Act, OWASP, SOC 2 (in progress), Audit trails
  [
    "https://doc.moleculesai.app/trust/eu-ai-act",
    "https://doc.moleculesai.app/trust/owasp",
    "https://doc.moleculesai.app/trust/soc2",
    "https://doc.moleculesai.app/trust/audit-trails",
  ],
];

// Localized aria-label for the hero card's data-topology SVG (a JS-driven
// animated diagram of A2A traffic between coordinator and team agents).
// Without this, screen readers announce the SVG as "graphic" with no context.
const heroSvgAlt: Record<"en" | "zh" | "es" | "fr" | "ja", string> = {
  en: "Live agent topology — A2A traffic between coordinator and team agents",
  zh: "实时智能体拓扑 — 协调者与团队智能体之间的 A2A 通信",
  es: "Topología de agentes en vivo — tráfico A2A entre coordinador y agentes del equipo",
  fr: "Topologie d'agents en direct — trafic A2A entre coordinateur et agents d'équipe",
  ja: "ライブのエージェント トポロジー — コーディネーターとチーム エージェントの間の A2A 通信",
};

// Localized aria-label for the use-case agent topology SVG (the per-tab
// diagram in the use-cases section). The diagram itself stays in code-
// config English (role names, tool/plugin slugs) because investors
// expect to see real workspace.yml syntax — but the alt text describes
// *what the diagram represents*, which should be in the user's language.
const useCaseSvgAlt: Record<"en" | "zh" | "es" | "fr" | "ja", string> = {
  en: "Agent topology — central org with surrounding role agents and their tools",
  zh: "智能体拓扑 — 中心组织、周围角色智能体及其工具",
  es: "Topología de agentes — organización central con agentes de rol y sus herramientas",
  fr: "Topologie d'agents — organisation centrale avec agents de rôle et leurs outils",
  ja: "エージェント トポロジー — 中心の組織と周囲のロール エージェント、そのツール",
};
---

{/* Scroll-progress indicator — thin accent bar pinned to the top of
    the viewport that fills as the user scrolls. Common investor-pitch
    landing-page pattern; helps a viewer parse "how far through am I"
    during a long-page demo. Pure CSS via animation-timeline:scroll()
    in modern browsers; small JS fallback for Safari < 18 / older
    Chromium. Reduced-motion users still see the indicator (it's a
    spatial cue, not animation), but the JS fallback skips repainting
    on every scroll event by passive-listening only. */}
<div class="v2-scroll-progress" aria-hidden="true"></div>

{/* Floating "back to top" — appears after the user scrolls past
    ~600px (roughly past the hero), smooth-scrolls back to top on
    click. Hidden state purely CSS-driven via scroll-timeline; the
    click handler doesn't even need to feature-detect the show/hide
    behavior. */}
<button
  type="button"
  class="v2-back-to-top"
  data-back-to-top
  aria-label="Back to top"
  title="Back to top"
>
  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
    <path d="M7 11 L7 3 M3 6 L7 2 L11 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
</button>

<header class="v2-nav">
  <div class="v2-statusbar">
    <span>
      <i class="dot dot-good pulsing" aria-hidden="true"></i>
      {c.statusbar.allSystems}
      <span aria-hidden="true"> · </span>
      <a class="v2-status-link" href="https://status.moleculesai.app" rel="noopener noreferrer" target="_blank">{c.statusbar.statusLink}</a>
    </span>
    <span>{c.statusbar.phase}</span>
  </div>
  <div class="v2-nav-row">
    <a class="v2-brand" href={locale === "zh" ? "/zh/" : locale === "fr" ? "/fr/" : locale === "ja" ? "/ja/" : locale === "es" ? "/es/" : "/"}>
      <svg aria-hidden="true" width="24" height="24" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="6" r="2.5" fill="currentColor" />
        <circle cx="6" cy="20" r="2.5" fill="currentColor" />
        <circle cx="22" cy="20" r="2.5" fill="currentColor" />
        <circle cx="14" cy="14" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2" />
        <line x1="14" y1="8.5" x2="14" y2="12.6" stroke="currentColor" stroke-width="1.2" />
        <line x1="8" y1="18.5" x2="12.7" y2="14.8" stroke="currentColor" stroke-width="1.2" />
        <line x1="20" y1="18.5" x2="15.3" y2="14.8" stroke="currentColor" stroke-width="1.2" />
      </svg>
      <span class="v2-brand-name">Molecule</span>
      <span class="v2-brand-tag">AI</span>
    </a>
    <nav class="v2-nav-links">
      {c.nav.links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a>
      ))}
    </nav>
    <div class="v2-nav-cta">
      <LocaleDropdown current={locale} />
      <ThemeToggle client:idle />
      <a class="v2-btn v2-btn-primary" href="https://app.moleculesai.app">{c.nav.signIn}</a>
      {/* Mobile hamburger — native <details> for click-out + a11y, mirrors
          the <LocaleDropdown> shape. Hidden on desktop; shown via the
          same 640px breakpoint that hides .v2-nav-links. */}
      <details class="v2-nav-mobile">
        <summary aria-label="Navigation menu" aria-haspopup="true">
          <svg
            class="v2-nav-mobile-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
        </summary>
        <nav aria-label="Mobile navigation">
          <ul>
            {c.nav.links.map((l) => (
              <li>
                <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<main id="main" tabindex="-1">
  {/* HERO */}
  <section class="v2-section v2-hero">
    <canvas data-particle data-density="0.00006" data-line="120"></canvas>
    <div class="v2-container v2-hero-grid">
      <div>
        <div class="v2-eyebrow" data-reveal>
          <span class="dot dot-warm"></span>
          <ShinyText client:visible text={c.hero.eyebrow} speed="3.5s" />
        </div>
        <h1 class="v2-h1">
          <BlurText client:visible text={c.hero.h1Lead} delay={70} />
          <br />
          <span class="v2-h1-shimmer">{c.hero.h1Highlight}</span>
        </h1>
        <p class="v2-lede" data-reveal data-delay="160">{c.hero.lede}</p>
        <div class="v2-cta-row" data-reveal data-delay="240">
          <a class="v2-btn v2-btn-primary v2-btn-lg" href="https://github.com/Molecule-AI/molecule-monorepo" rel="noopener noreferrer" target="_blank">{c.hero.primaryCta}</a>
          <a class="v2-btn v2-btn-ghost v2-btn-lg" href="https://app.moleculesai.app" rel="noopener noreferrer" target="_blank" data-pulse-on-view>{c.hero.secondaryCta}</a>
        </div>
        <div class="v2-stat-row" data-reveal data-delay="320">
          {c.hero.stats.map((s) => (
            <div>
              <span class="v2-counter" data-counter={s.to} data-suffix={s.suffix ?? ""}>0</span>
              <em>{s.label}</em>
            </div>
          ))}
        </div>
      </div>
      <div class="v2-hero-card" data-reveal data-delay="120">
        <div class="v2-hero-card-chrome">
          <span>{c.hero.heroCardUrl}</span>
          <span><i class="dot dot-good pulsing"></i>{c.hero.heroCardA2ALabel} · <span data-a2a>42</span> {c.hero.heroCardA2ASuffix}</span>
        </div>
        <svg data-topology viewBox="0 0 560 420" width="100%" style="display:block" role="img" aria-label={heroSvgAlt[locale]}></svg>
      </div>
    </div>
  </section>

  {/* LOGO STRIP */}
  <section class="v2-section v2-logo-strip">
    <div class="v2-logo-eyebrow">
      <DecryptedText client:visible text={c.logoStrip.eyebrow} speed={28} />
    </div>
    <div class="v2-marquee">
      <div class="v2-marquee-track">
        {[...c.logoStrip.runtimes, ...c.logoStrip.runtimes].map((n) => {
          // Display label → docs slug: lowercase + spaces to hyphens.
          // "Claude Code" → "claude-code", "Gemini CLI" → "gemini-cli".
          // Matches the URL shape used by footerHrefs[2] (Runtimes column).
          const slug = n.toLowerCase().replace(/\s+/g, "-");
          return (
            <a
              class="v2-marquee-item"
              href={`https://doc.moleculesai.app/adapters/${slug}`}
              rel="noopener noreferrer"
              target="_blank"
              aria-label={`${n} adapter docs`}
            >
              <i class="dot dot-accent" aria-hidden="true"></i>
              {n}
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* WHY NOW */}
  <section id="why-now" class="v2-section">
    <div class="v2-container">
      <div class="v2-section-head">
        <div>
          <div class="v2-kicker" data-reveal>
            <SplitText client:visible text={c.whyNow.kicker} delay={45} animateBy="chars" />
          </div>
          <h2 class="v2-h2">
            <BlurText client:visible text={c.whyNow.title} delay={60} />
          </h2>
        </div>
      </div>
      <div class="v2-grid-4">
        {c.whyNow.reasons.map((r, i) => (
          <div data-reveal data-delay={i * 90}>
            <SpotlightCard client:visible className="v2-card v2-card-hover h-full" spotlightColor="rgba(127,232,214,0.14)">
              <div class="v2-card-icon" set:html={whyNowGlyphs[i]} />
              <div class="v2-keynum">{r.k}</div>
              <h3 class="v2-card-title">{r.title}</h3>
              <p class="v2-card-body">{r.body}</p>
            </SpotlightCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* USE CASES */}
  <section id="use-cases" class="v2-section v2-section-ink">
    <div class="v2-container">
      <div class="v2-section-head">
        <div>
          <div class="v2-kicker" data-reveal>{c.useCases.kicker}</div>
          <h2 class="v2-h2">
            <BlurText client:visible text={c.useCases.title} delay={60} />
          </h2>
        </div>
      </div>
