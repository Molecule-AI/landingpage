    let inkMid = styles.getPropertyValue("--inkMid").trim() || "#5a5e66";
    let bgElev = styles.getPropertyValue("--bgElev").trim() || "#ffffff";

    const drawNode = (
      x: number,
      y: number,
      label: string,
      opts: { root?: boolean; small?: boolean }
    ) => {
      const baseR = opts.root ? 24 : opts.small ? 14 : 18;
      const g = document.createElementNS(svgNs, "g");
      // Make non-root nodes feel grabbable in CSS even before the
      // pointerdown handler fires.
      if (!opts.root) g.style.cursor = "grab";
      const ring = document.createElementNS(svgNs, "circle");
      ring.setAttribute("cx", String(x));
      ring.setAttribute("cy", String(y));
      ring.setAttribute("r", "0");
      ring.setAttribute("fill", "none");
      ring.setAttribute("stroke", accent);
      ring.setAttribute("stroke-width", "1.2");
      g.appendChild(ring);
      const outer = document.createElementNS(svgNs, "circle");
      outer.setAttribute("cx", String(x));
      outer.setAttribute("cy", String(y));
      outer.setAttribute("r", String(baseR));
      outer.setAttribute("fill", bgElev);
      outer.setAttribute("stroke", ink);
      outer.setAttribute("stroke-width", "1");
      g.appendChild(outer);
      const inner = document.createElementNS(svgNs, "circle");
      inner.setAttribute("cx", String(x));
      inner.setAttribute("cy", String(y));
      inner.setAttribute("r", String(baseR - 7));
      inner.setAttribute("fill", opts.root ? ink : inkMid);
      // Root + non-leaf inner circles never get rewritten by animate().
      // CSS class wins over the cached fill attr so theme toggle works.
      // Leaf inners are mutated every frame, so the closure-mutable
      // `inkMid` (refreshed by the MutationObserver) handles them.
      if (opts.root) inner.setAttribute("class", "v2-topo-inner-root");
      else if (!opts.small) inner.setAttribute("class", "v2-topo-inner-mid");
      if (opts.small) inner.setAttribute("opacity", "0.55");
      g.appendChild(inner);
      const tx = document.createElementNS(svgNs, "text");
      tx.setAttribute("x", String(x));
      tx.setAttribute("y", String(y + baseR + 14));
      tx.setAttribute("text-anchor", "middle");
      tx.setAttribute("font-size", "10");
      tx.setAttribute("font-family", "ui-monospace, monospace");
      // CSS class wins over the fill attribute, so this stays theme-reactive
      // even after the user toggles theme post-page-load (the cached `inkMid`
      // resolved hex would otherwise stay light-theme on a dark page).
      tx.setAttribute("class", "v2-topo-label");
      tx.setAttribute("fill", inkMid);
      tx.textContent = label;
      g.appendChild(tx);
      nodes.appendChild(g);
      return { ring, outer, inner, baseR, label: tx, group: g };
    };

    mids.forEach((m) => {
      const ln = document.createElementNS(svgNs, "line");
      ln.setAttribute("x1", String(root.x));
      ln.setAttribute("y1", String(root.y));
      ln.setAttribute("x2", String(m.x));
      ln.setAttribute("y2", String(m.y));
      ln.setAttribute("stroke", ink);
      ln.setAttribute("stroke-opacity", "0.22");
      ln.setAttribute("stroke-width", "1");
      // Static mid-edges aren't touched by animate(); CSS class makes
      // the stroke theme-reactive without needing repaint.
      ln.setAttribute("class", "v2-topo-edge-static");
      edges.appendChild(ln);
    });
    const leafEdges = leaves.map((l) => {
      const m = mids[l.p];
      const ln = document.createElementNS(svgNs, "line");
      ln.setAttribute("x1", String(m.x));
      ln.setAttribute("y1", String(m.y));
      ln.setAttribute("x2", String(l.x));
      ln.setAttribute("y2", String(l.y));
      ln.setAttribute("stroke", ink);
      ln.setAttribute("stroke-opacity", "0.18");
      ln.setAttribute("stroke-width", "1");
      edges.appendChild(ln);
      return ln;
    });

    const rootN = drawNode(root.x, root.y, root.label, { root: true });
    const midNs = mids.map((m) => drawNode(m.x, m.y, m.label, {}));
    const leafNs = leaves.map((l) => drawNode(l.x, l.y, l.label, { small: true }));

    // Drag-to-rearrange. Hovering a non-root node shows `cursor: grab`
    // (set in drawNode); pointerdown captures, pointermove updates the
    // node's stored coords + repositions its circles/label + repaints
    // every connected edge endpoint. Packets continue to animate over
    // the live positions because the animate() loop reads from the
    // mutable {root, mids[], leaves[]} arrays each frame. Dragging a
    // mid drags every child leaf edge with it. Root is intentionally
    // not draggable — it's the coordinator anchor.
    if (!prefersReducedMotion) {
      const screenToSvg = (clientX: number, clientY: number) => {
        const rect = tSvg.getBoundingClientRect();
        return {
          x: ((clientX - rect.left) / rect.width) * w,
          y: ((clientY - rect.top) / rect.height) * h,
        };
      };
      const moveNodeChildren = (nodeRef: { ring: SVGCircleElement; outer: SVGCircleElement; inner: SVGCircleElement; label: SVGTextElement; baseR: number }, x: number, y: number) => {
        nodeRef.ring.setAttribute("cx", String(x));
        nodeRef.ring.setAttribute("cy", String(y));
        nodeRef.outer.setAttribute("cx", String(x));
        nodeRef.outer.setAttribute("cy", String(y));
        nodeRef.inner.setAttribute("cx", String(x));
        nodeRef.inner.setAttribute("cy", String(y));
        nodeRef.label.setAttribute("x", String(x));
        nodeRef.label.setAttribute("y", String(y + nodeRef.baseR + 14));
      };
      type DragKind = "mid" | "leaf";
      let drag: { kind: DragKind; idx: number; offX: number; offY: number; nodeRef: typeof midNs[number] } | null = null;
      const beginDrag = (kind: DragKind, idx: number) => (e: PointerEvent) => {
        e.preventDefault();
        const pt = screenToSvg(e.clientX, e.clientY);
        const src = kind === "mid" ? mids[idx] : leaves[idx];
        const nodeRef = kind === "mid" ? midNs[idx] : leafNs[idx];
        drag = { kind, idx, offX: pt.x - src.x, offY: pt.y - src.y, nodeRef };
        nodeRef.group.style.cursor = "grabbing";
        // Pointer capture so a fast drag that leaves the SVG keeps
        // updating until pointerup. tSvg gets the events because we
        // bind move/up there.
        try { tSvg.setPointerCapture(e.pointerId); } catch { /* noop */ }
      };
      midNs.forEach((n, i) => n.group.addEventListener("pointerdown", beginDrag("mid", i)));
      leafNs.forEach((n, i) => n.group.addEventListener("pointerdown", beginDrag("leaf", i)));

      tSvg.addEventListener("pointermove", (e) => {
        if (!drag) return;
        const pt = screenToSvg(e.clientX, e.clientY);
        // Clamp to viewBox with a 30px margin so labels don't clip.
        const nx = Math.max(40, Math.min(w - 40, pt.x - drag.offX));
        const ny = Math.max(40, Math.min(h - 40, pt.y - drag.offY));
        if (drag.kind === "mid") {
          mids[drag.idx].x = nx;
          mids[drag.idx].y = ny;
          moveNodeChildren(drag.nodeRef, nx, ny);
          // Move root→mid edge.
          const rootMidEdge = edges.children[drag.idx] as SVGLineElement | undefined;
          if (rootMidEdge) {
            rootMidEdge.setAttribute("x2", String(nx));
            rootMidEdge.setAttribute("y2", String(ny));
          }
          // Move every leaf-edge whose parent is this mid.
          leafEdges.forEach((ln, li) => {
            if (leaves[li].p === drag!.idx) {
              ln.setAttribute("x1", String(nx));
              ln.setAttribute("y1", String(ny));
            }
          });
        } else {
          leaves[drag.idx].x = nx;
          leaves[drag.idx].y = ny;
          moveNodeChildren(drag.nodeRef, nx, ny);
          const ln = leafEdges[drag.idx];
          ln.setAttribute("x2", String(nx));
          ln.setAttribute("y2", String(ny));
        }
      });
      const endDrag = (e: PointerEvent) => {
        if (!drag) return;
        drag.nodeRef.group.style.cursor = "grab";
        try { tSvg.releasePointerCapture(e.pointerId); } catch { /* noop */ }
        drag = null;
      };
      tSvg.addEventListener("pointerup", endDrag);
      tSvg.addEventListener("pointercancel", endDrag);
    }

    const pkts = [0, 0.33, 0.66].map(() => {
      const g = document.createElementNS(svgNs, "g");
      const halo = document.createElementNS(svgNs, "circle");
      halo.setAttribute("r", "14");
      halo.setAttribute("fill", "url(#lt-glow)");
      g.appendChild(halo);
      const dot = document.createElementNS(svgNs, "circle");
      dot.setAttribute("r", "3.5");
      dot.setAttribute("fill", accent);
      g.appendChild(dot);
      pktLayer.appendChild(g);
      return { g, halo, dot };
    });

    // IO-gated rAF: animate() chains itself via requestAnimationFrame.
    // When the SVG scrolls offscreen we flip animActive=false so the
    // next chain call returns early and the loop stops. When it scrolls
    // back into view, the IO callback restarts the chain. Saves the
    // ~20-element-per-frame attribute writes on every page after the
    // user scrolls past the hero (which is most of the time).
    let animActive = true;
    const animate = () => {
      if (!animActive) return;
      const time = performance.now() / 1000;
      [rootN, ...midNs, ...leafNs].forEach((n, i) => {
        const breathe = Math.sin(time * 1.4 + i * 0.3) * 1.2;
        n.outer.setAttribute("r", String(n.baseR + breathe * 0.4));
      });
      const streams = [0, 0.33, 0.66].map((off) => {
        const phase = ((time * 0.45) + off) % 1;
        const idx = Math.floor((time * 0.45 + off) % leaves.length);
        return { phase, idx: idx % leaves.length };
      });
      leafEdges.forEach((ln, i) => {
        const hot = streams.some((s) => s.idx === i);
        ln.setAttribute("stroke", hot ? accent : ink);
        ln.setAttribute("stroke-opacity", hot ? "0.85" : "0.18");
        ln.setAttribute("stroke-width", hot ? "1.6" : "1");
      });
      leafNs.forEach((n, i) => {
        const active = streams.some((s) => s.idx === i);
        if (active) {
          const ringR = n.baseR + 6 + (Math.sin(time * 2 + i * 0.2) * 0.5 + 0.5) * 8;
          const ringO = Math.max(0, 0.7 - (Math.sin(time * 2 + i * 0.2) * 0.5 + 0.5) * 0.7);
          n.ring.setAttribute("r", String(ringR));
          n.ring.setAttribute("stroke-opacity", String(ringO));
          n.outer.setAttribute("stroke", accent);
          n.outer.setAttribute("stroke-width", "2");
          n.inner.setAttribute("fill", accent);
        } else {
          n.ring.setAttribute("r", "0");
          n.outer.setAttribute("stroke", ink);
          n.outer.setAttribute("stroke-width", "1");
          n.inner.setAttribute("fill", inkMid);
        }
      });
      streams.forEach((s, i) => {
        const target = leaves[s.idx];
        const m = mids[target.p];
        const p = s.phase;
        let x: number, y: number;
        if (p < 0.5) {
          const k = p / 0.5;
          x = root.x + (m.x - root.x) * k;
          y = root.y + (m.y - root.y) * k;
        } else {
          const k = (p - 0.5) / 0.5;
          x = m.x + (target.x - m.x) * k;
          y = m.y + (target.y - m.y) * k;
        }
        pkts[i].halo.setAttribute("cx", String(x));
        pkts[i].halo.setAttribute("cy", String(y));
        pkts[i].dot.setAttribute("cx", String(x));
        pkts[i].dot.setAttribute("cy", String(y));
      });
      requestAnimationFrame(animate);
    };
    if (prefersReducedMotion) {
      // Render the static topology once (nodes + edges already drawn);
      // hide the moving packet dots so the SVG reads as a still diagram.
      pkts.forEach(({ halo, dot }) => {
        halo.setAttribute("opacity", "0");
        dot.setAttribute("opacity", "0");
      });
    } else {
      requestAnimationFrame(animate);
      // Pause the rAF chain when the SVG scrolls offscreen so the live-
      // topology animation isn't burning CPU on every page below the
      // hero. 100px rootMargin restarts a tick before it re-enters
      // view, hiding the resume from the user.
      new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !animActive) {
            animActive = true;
            requestAnimationFrame(animate);
          } else if (!e.isIntersecting && animActive) {
            animActive = false;
          }
        }
      }, { rootMargin: "100px" }).observe(tSvg);
    }

    // Theme-toggle reactivity: re-read the cached color vars when
    // <html data-theme> changes so the next animate() pass picks
    // them up. CSS classes on static SVG attrs (added above) cover
    // the never-rewritten elements; this handles leaf-edge strokes
    // + leaf-inner fills + canvas particle networks that DO get
    // rewritten every frame from the closure-captured vars.
    new MutationObserver(() => {
      const s = getComputedStyle(document.body);
      ink = s.getPropertyValue("--ink").trim() || ink;
      inkMid = s.getPropertyValue("--inkMid").trim() || inkMid;
      bgElev = s.getPropertyValue("--bgElev").trim() || bgElev;
      accent = s.getPropertyValue("--accent").trim() || accent;
      warm = s.getPropertyValue("--warm").trim() || warm;
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }

  // Use case tabs — animated agent topology + deploy steps + YAML toggle.
  // The right-pane was a static YAML dump (user feedback: "too boring and
  // developer-y"); now it renders an SVG topology of the org so investors
  // see agents/runtimes/HITL gates instead of config code.
  type Cache = { yaml: string; kicker: string; label: string; deploy: string };
  const yamlCache = new Map<string, Cache>();
  document.querySelectorAll<HTMLScriptElement>("script[data-yaml]").forEach((el) => {
    const id = el.getAttribute("data-yaml")!;
    try {
      yamlCache.set(id, JSON.parse(el.textContent || "{}"));
    } catch {
      // ignore
    }
  });
  const yamlTarget = document.querySelector<HTMLPreElement>("[data-yaml-target]");
  const metaKicker = document.querySelector<HTMLElement>("[data-meta-kicker]");
  const metaLabel = document.querySelector<HTMLElement>("[data-meta-label]");
  const cmdEl = document.querySelector<HTMLElement>("[data-cmd]");
  const deploySteps = document.querySelectorAll<HTMLElement>("[data-deploy] .v2-deploy-step");
  const ucDiagram = document.querySelector<HTMLElement>("[data-usecase-diagram]");
  const ucSvg = document.querySelector<SVGSVGElement>("svg[data-usecase-svg]");
  const ucToggle = document.querySelector<HTMLButtonElement>("[data-diagram-toggle]");
  const diagramTitleEl = document.querySelector<HTMLElement>("[data-diagram-title]");
  let deployTimers: ReturnType<typeof setTimeout>[] = [];
  let revealTimers: ReturnType<typeof setTimeout>[] = [];

  // Tiny YAML parser tailored to USECASE_YAMLS shape (org / agents[] / hitl[] /
  // memory). We don't need a general YAML lib — these strings are well-formed
  // and small. Lines look like `org: x`, `  - role: y`, `    runtime: z`,
  // `    tools: [a, b]`, `    plugins: [a, b]`, `    count: 2`.
  type Agent = {
    role: string;
    runtime: string;
    tools: string[];
    plugins: string[];
    count: number;
  };
  type ParsedYaml = {
    org: string;
    agents: Agent[];
    hitl: string[];
    memory: string | null;
  };
  const parseUsecaseYaml = (src: string): ParsedYaml => {
    const out: ParsedYaml = { org: "", agents: [], hitl: [], memory: null };
    const lines = src.split("\n");
    let mode: "top" | "agents" | "hitl" | "memory" = "top";
    let cur: Agent | null = null;
    const parseList = (raw: string): string[] =>
      raw
        .replace(/^\[/, "")
        .replace(/\]$/, "")
        .split(",")
        .map((s) => s.trim())
        .filter(Boolean);
    for (const ln of lines) {
      if (!ln.trim()) continue;
      const m = /^(\s*)(.*)$/.exec(ln)!;
      const indent = m[1].length;
      const body = m[2];
      if (indent === 0) {
        if (body.startsWith("org:")) out.org = body.slice(4).trim();
        else if (body.startsWith("agents:")) {
          mode = "agents";
          cur = null;
        } else if (body.startsWith("hitl:")) {
          mode = "hitl";
          cur = null;
        } else if (body.startsWith("memory:")) {
          mode = "memory";
          cur = null;
        } else mode = "top";
        continue;
      }
      if (mode === "agents") {
        if (body.startsWith("- ")) {
          cur = { role: "", runtime: "", tools: [], plugins: [], count: 1 };
          out.agents.push(cur);
          const inner = body.slice(2).trim();
          if (inner.startsWith("role:")) cur.role = inner.slice(5).trim();
        } else if (cur) {
          if (body.startsWith("role:")) cur.role = body.slice(5).trim();
          else if (body.startsWith("runtime:")) cur.runtime = body.slice(8).trim();
          else if (body.startsWith("count:")) cur.count = Number(body.slice(6).trim()) || 1;
          else if (body.startsWith("tools:")) cur.tools = parseList(body.slice(6).trim());
          else if (body.startsWith("plugins:")) cur.plugins = parseList(body.slice(8).trim());
        }
      } else if (mode === "hitl") {
        if (body.startsWith("- ")) out.hitl.push(body.slice(2).trim());
      } else if (mode === "memory") {
        // Best-effort: capture the first scope line for the diagram label.
        if (body.includes("scope:")) {
          const sm = /scope:\s*([\w-]+)/.exec(body);
          if (sm) out.memory = sm[1];
        }
      }
    }
    return out;
  };

  // Map runtime names to short badge labels (kept under 6 chars so they
  // fit inside the agent node's runtime pill without truncation).
  const runtimeBadge = (rt: string): string => {
    const r = rt.toLowerCase();
    if (r === "claude-code") return "claude";
    if (r === "langgraph") return "lgraph";
    if (r === "deepagents") return "deep";
    if (r === "hermes") return "hermes";
    if (r === "crewai") return "crew";
    if (r === "autogen") return "autog";
    if (r === "gemini-cli") return "gemini";
    return r.slice(0, 6) || "agent";
  };

  const SVG_NS = "http://www.w3.org/2000/svg";
  const el = (
    name: string,
    attrs: Record<string, string | number> = {},
    parent?: SVGElement | null
  ): SVGElement => {
    const node = document.createElementNS(SVG_NS, name);
    for (const [k, v] of Object.entries(attrs)) node.setAttribute(k, String(v));
    if (parent) parent.appendChild(node);
    return node;
  };

  // Listeners on ucSvg itself (pointermove/up/cancel for drag) survive
  // tab swaps because we only clear ucSvg.firstChild — the SVG element
  // and its event listeners persist across renderDiagram calls. An
  // AbortController lets the next render kill the previous render's
  // listeners on ucSvg in one shot, preventing N listeners after N
  // tab clicks. Children-level listeners (pointerdown on each agent
  // group) are removed automatically when the children are GC'd, so
  // they don't need this treatment.
  let dragAbortController: AbortController | null = null;
  const renderDiagram = (parsed: ParsedYaml) => {
    if (!ucSvg) return;
    while (ucSvg.firstChild) ucSvg.removeChild(ucSvg.firstChild);
    if (dragAbortController) dragAbortController.abort();
    dragAbortController = new AbortController();
    revealTimers.forEach(clearTimeout);
    revealTimers = [];

    // Expand agents with `count: N` into N siblings so the diagram shows
    // the actual head-count (lab YAML has `postdoc count: 2`).
    const slots: { agent: Agent; suffix: string }[] = [];
    parsed.agents.forEach((a) => {
      if (a.count > 1) {
        for (let i = 0; i < a.count; i++)
          slots.push({ agent: a, suffix: `·${i + 1}` });
      } else {
        slots.push({ agent: a, suffix: "" });
      }
    });

    const W = 520;
    const H = 360;
    const cx = W / 2;
    const cy = H / 2;
    const orgR = 38;
    const agentR = 22;
    const ringR = Math.min(118, 60 + slots.length * 8);

    // Optional memory ring (drawn first, behind everything).
    if (parsed.memory) {
      el("circle", {
        cx,
        cy,
        r: ringR + 36,
        class: "v2-uc-memory-bg v2-uc-anim",
        "data-anim": "memory",
        "fill-opacity": "1",
      }, ucSvg);
      const mt = el("text", {
        x: cx,
        y: cy - (ringR + 28),
        "text-anchor": "middle",
        class: "v2-uc-sublabel v2-uc-anim",
        "data-anim": "memory",
      }, ucSvg);
      mt.textContent = `memory · ${parsed.memory}`;
    }

    // Agent positions on the ring.
    const N = slots.length;
    const positions = slots.map((_, i) => {
      // Start at -90deg (top) and go clockwise.
      const angle = -Math.PI / 2 + (i * 2 * Math.PI) / Math.max(N, 1);
      return { x: cx + Math.cos(angle) * ringR, y: cy + Math.sin(angle) * ringR, angle };
    });

    // Edges first so nodes paint over them.
    const edges: SVGElement[] = [];
    // Track HITL chip wrappers per-agent index so drag can move them
    // along with the edge midpoint they're anchored to. Sparse — only
    // agents that triggered a HITL rule get an entry.
    const hitlWrappers = new Map<number, SVGElement>();
    // Track per-agent position wrappers + drag state.
    const agentPositionGs: SVGElement[] = new Array(slots.length);
    positions.forEach((p, i) => {
      const dx = p.x - cx;
      const dy = p.y - cy;
      const len = Math.sqrt(dx * dx + dy * dy);
      const ux = dx / len;
      const uy = dy / len;
      const x1 = cx + ux * orgR;
      const y1 = cy + uy * orgR;
      const x2 = p.x - ux * agentR;
      const y2 = p.y - uy * agentR;
      const ln = el("line", {
        x1,
        y1,
        x2,
        y2,
        "stroke-width": 1.4,
        class: "v2-uc-edge v2-uc-anim",
        "data-anim": "edge",
      }, ucSvg) as SVGLineElement;
      // Anchor the scaleX transform at the org-side endpoint so the line
      // appears to grow outward from the org node toward the agent.
      ln.style.transformOrigin = `${x1}px ${y1}px`;
      edges.push(ln);
      // HITL gate badge: if the agent role appears in any hitl rule, drop a
      // small chip on the midpoint of the edge.
      const slot = slots[i];
      const hitForRole = parsed.hitl.find((rule) =>
        rule.toLowerCase().includes(slot.agent.role.toLowerCase())
      );
      // soc YAML's "severity >= high → l3 + ir-lead" — match l3 / ir-lead.
      // fintech YAML's "amount > 10_000 → dual_review" — applies to all
      // money-handling agents; we tag cfo + compliance heuristically.
      const ruleApplies =
        hitForRole !== undefined ||
        (parsed.hitl.length > 0 &&
          (slot.agent.role === "cfo" || slot.agent.role === "compliance"));
      if (ruleApplies) {
        const mx = (x1 + x2) / 2;
        const my = (y1 + y2) / 2;
        // Position via outer <g>'s transform attribute, animate the inner.
        // CSS `transform` on `.v2-uc-anim` would otherwise OVERRIDE the
        // positional attribute (CSS property always wins over SVG attr —
        // they don't compose), collapsing every HITL chip to the SVG
        // coordinate origin. Outer = position, inner = entrance animation.
        const positionG = el("g", {
          transform: `translate(${mx} ${my})`,
        }, ucSvg);
        hitlWrappers.set(i, positionG);
        const g = el("g", {
          class: "v2-uc-anim",
          "data-anim": "hitl",
        }, positionG);
        el("rect", {
          x: -22,
          y: -8,
          width: 44,
          height: 16,
          rx: 8,
          ry: 8,
          class: "v2-uc-hitl-bg",
          "stroke-width": 1,
        }, g);
        const t = el("text", {
          x: 0,
          y: 3.5,
          "text-anchor": "middle",
          class: "v2-uc-hitl-text",
        }, g);
        t.textContent = "HITL";
      }
    });

    // Agent nodes.
    positions.forEach((p, i) => {
      const slot = slots[i];
      // Same outer-position / inner-animate split as the HITL chips —
      // see the comment above. Without this, every agent <g> would
      // collapse to (0, 0) and the entire ring would stack at top-left.
      const positionG = el("g", {
        transform: `translate(${p.x} ${p.y})`,
      }, ucSvg);
      // Track for drag-to-rearrange (mirrors the hero topology drag —
      // PR #101 — but adapted to the use-case diagram's per-agent
      // positionG / edges[i] / hitlWrappers shape).
      agentPositionGs[i] = positionG;
      positionG.style.cursor = "grab";
      const g = el("g", {
        class: "v2-uc-anim",
        "data-anim": `agent-${i}`,
      }, positionG);
      el("circle", {
        cx: 0,
        cy: 0,
        r: agentR,
        "stroke-width": 1.2,
        class: "v2-uc-agent-fill",
      }, g);
      el("circle", {
        cx: 0,
        cy: 0,
        r: agentR - 9,
        class: "v2-uc-agent-inner",
      }, g);
      // Role label below the node. Push it further out for nodes on the
      // bottom half so it doesn't overlap with neighbors.
      const labelDy = p.y > cy ? agentR + 14 : -(agentR + 8);
      const lbl = el("text", {
        x: 0,
        y: labelDy,
        "text-anchor": "middle",
        class: "v2-uc-label",
      }, g);
      lbl.textContent = slot.agent.role + slot.suffix;
      // Runtime pill below the role label (or above for top-half nodes).
      const rtDy = p.y > cy ? labelDy + 14 : labelDy - 12;
      const rtTxt = runtimeBadge(slot.agent.runtime);
      const pillW = Math.max(34, rtTxt.length * 6 + 10);
      const rtg = el("g", {
        transform: `translate(${-pillW / 2} ${rtDy - 8})`,
      }, g);
      el("rect", {
        x: 0,
        y: 0,
        width: pillW,
        height: 14,
        rx: 7,
        ry: 7,
        "stroke-width": 1,
        class: "v2-uc-runtime-bg",
      }, rtg);
      const rtTextEl = el("text", {
        x: pillW / 2,
        y: 9.5,
        "text-anchor": "middle",
        class: "v2-uc-runtime-text",
      }, rtg);
      rtTextEl.textContent = rtTxt;

      // Tool / plugin chips placed HORIZONTALLY on the outer-x side of
      // the agent. Radial placement (the previous approach) put chips
      // along the same axis as the label+pill stack, causing them to
      // overlap the label visually — see PR #93. Horizontal cursor-based
      // layout keeps chips strictly to one side of the agent and walks
      // outward by each chip's own width, so they never collide with
      // each other and never collide with the vertical label column.
      const chips = [...slot.agent.tools, ...slot.agent.plugins].slice(0, 3);
      if (chips.length) {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const len = Math.sqrt(dx * dx + dy * dy) || 1;
        const ux = dx / len;
        const uy = dy / len;
        // Right-side chips for agents on the right half (or center-top
        // / center-bottom, where there's no rightward neighbor to
        // avoid). Left-side for the rest. Falls back gracefully when
        // ux is near zero.
        const horizDir = ux >= 0 ? 1 : -1;
        let xCursor = agentR + 6;
        chips.forEach((tool) => {
          const w = Math.max(28, tool.length * 5.2 + 10);
          const tx = horizDir * (xCursor + w / 2);
          // Slight upward bias so chips center on a line a hair above
          // the agent center — leaves more room for the label/pill
          // stack rendering directly below the agent.
          const ty = -4;
          const tg = el("g", {
            transform: `translate(${tx - w / 2} ${ty})`,
          }, g);
          xCursor += w + 4;
          el("rect", {
            x: 0,
            y: 0,
            width: w,
            height: 12,
            rx: 6,
            ry: 6,
            "stroke-width": 0.8,
            class: "v2-uc-tool",
          }, tg);
          const tt = el("text", {
            x: w / 2,
            y: 8.5,
            "text-anchor": "middle",
            class: "v2-uc-tool-text",
          }, tg);
          tt.textContent = tool;
        });
      }
    });

    // Org node last so it sits on top of all edges. Outer <g> positions
    // it at the SVG center; inner <g> carries the entrance animation
    // class. Splitting prevents CSS `.v2-uc-anim` transform from
    // clobbering the positional translate.
    const orgPositionG = el("g", {
      transform: `translate(${cx} ${cy})`,
    }, ucSvg);
    const orgG = el("g", {
      class: "v2-uc-anim",
      "data-anim": "org",
    }, orgPositionG);
    el("circle", {
      cx: 0,
      cy: 0,
      r: orgR,
      class: "v2-uc-org-fill",
    }, orgG);
    // Wrap the org name on the disc — most are 1-2 words separated by `-`.
    const orgWords = parsed.org.split("-");
    if (orgWords.length === 1) {
      const tx = el("text", {
        x: 0,
        y: 4,
        "text-anchor": "middle",
        class: "v2-uc-org-label",
      }, orgG);
      tx.textContent = orgWords[0];
    } else {
      const lineH = 13;
      const startY = -((orgWords.length - 1) * lineH) / 2 + 4;
      orgWords.forEach((w, i) => {
        const tx = el("text", {
          x: 0,
          y: startY + i * lineH,
          "text-anchor": "middle",
          class: "v2-uc-org-label",
        }, orgG);
        tx.textContent = w;
      });
    }
    const orgKicker = el("text", {
      x: cx,
      y: cy + orgR + 14,
      "text-anchor": "middle",
      class: "v2-uc-sublabel",
    }, ucSvg);
    orgKicker.textContent = "org · A2A bus";

    // Stagger reveal: org first, then agents fanning out, then edges drawing,
    // then HITL gates settling on top. Reduce-motion CSS rule snaps to final.
    if (prefersReducedMotion) {
      ucSvg.querySelectorAll<SVGElement>(".v2-uc-anim").forEach((n) =>
        n.setAttribute("data-on", "true")
      );
      return;
    }
    const reveal = (selector: string, baseDelay: number, step: number) => {
      const list = Array.from(
        ucSvg.querySelectorAll<SVGElement>(selector)
      );
      list.forEach((n, idx) => {
        revealTimers.push(
          setTimeout(() => n.setAttribute("data-on", "true"), baseDelay + idx * step)
        );
      });
    };
    reveal('[data-anim="memory"]', 0, 80);
    reveal('[data-anim="org"]', 60, 80);
    // Stagger each agent group, then edges in parallel, then HITL gates.
    const agentNodes = Array.from(
      ucSvg.querySelectorAll<SVGElement>('[data-anim^="agent-"]')
    );
    agentNodes.forEach((n, idx) => {
      revealTimers.push(
        setTimeout(() => n.setAttribute("data-on", "true"), 220 + idx * 80)
      );
    });
    const edgeDelay = 220 + agentNodes.length * 80;
    reveal('[data-anim="edge"]', edgeDelay, 50);
    reveal('[data-anim="hitl"]', edgeDelay + 200, 60);

    // Drag-to-rearrange agents (same shape as the hero topology drag,
    // PR #101). Each agent's positionG carries cursor:grab; pointerdown
    // captures and tracks {idx, offX, offY}. pointermove updates the
    // positionG transform, the org→agent edge endpoint, and the HITL
    // chip midpoint if one is anchored to that edge. Reduced-motion
    // skips drag binding to match the entrance-animation skip below.
    if (!prefersReducedMotion) {
      const screenToSvg = (clientX: number, clientY: number) => {
        const rect = ucSvg.getBoundingClientRect();
        return {
          x: ((clientX - rect.left) / rect.width) * W,
          y: ((clientY - rect.top) / rect.height) * H,
        };
      };
      let drag: { idx: number; offX: number; offY: number } | null = null;
      const onDown = (idx: number) => (e: PointerEvent) => {
        e.preventDefault();
        const pt = screenToSvg(e.clientX, e.clientY);
        drag = { idx, offX: pt.x - positions[idx].x, offY: pt.y - positions[idx].y };
        agentPositionGs[idx].style.cursor = "grabbing";
        try { ucSvg.setPointerCapture(e.pointerId); } catch { /* noop */ }
      };
      const dragSignal = dragAbortController!.signal;
      agentPositionGs.forEach((pg, i) =>
        pg.addEventListener("pointerdown", onDown(i), { signal: dragSignal }),
      );
      ucSvg.addEventListener("pointermove", (e) => {
        if (!drag) return;
        const pt = screenToSvg(e.clientX, e.clientY);
        // Clamp inside the viewBox with a 30px margin so labels/chips
        // don't clip when dragged to the edge.
        const nx = Math.max(30, Math.min(W - 30, pt.x - drag.offX));
        const ny = Math.max(30, Math.min(H - 30, pt.y - drag.offY));
        positions[drag.idx].x = nx;
        positions[drag.idx].y = ny;
        agentPositionGs[drag.idx].setAttribute("transform", `translate(${nx} ${ny})`);
        // Recompute the edge endpoints for this agent. Org-side stays
        // anchored at orgR from cx/cy in the new direction; agent-side
        // sits at agentR inside the new position so the line touches
        // the circle edge, not the center.
        const dx = nx - cx, dy = ny - cy;
        const len = Math.sqrt(dx * dx + dy * dy) || 1;
        const ux = dx / len, uy = dy / len;
        const x1 = cx + ux * orgR, y1 = cy + uy * orgR;
        const x2 = nx - ux * agentR, y2 = ny - uy * agentR;
        const ln = edges[drag.idx] as SVGLineElement;
        ln.setAttribute("x1", String(x1));
        ln.setAttribute("y1", String(y1));
        ln.setAttribute("x2", String(x2));
        ln.setAttribute("y2", String(y2));
        ln.style.transformOrigin = `${x1}px ${y1}px`;
        // Move HITL chip with edge midpoint if one is anchored here.
        const hitl = hitlWrappers.get(drag.idx);
        if (hitl) {
          hitl.setAttribute("transform", `translate(${(x1 + x2) / 2} ${(y1 + y2) / 2})`);
        }
      }, { signal: dragSignal });
      const endDrag = (e: PointerEvent) => {
        if (!drag) return;
        agentPositionGs[drag.idx].style.cursor = "grab";
        try { ucSvg.releasePointerCapture(e.pointerId); } catch { /* noop */ }
        drag = null;
      };
      ucSvg.addEventListener("pointerup", endDrag, { signal: dragSignal });
      ucSvg.addEventListener("pointercancel", endDrag, { signal: dragSignal });
    }
  };

  // Track the currently-active tab so the reset button can re-render
  // the diagram for whichever tab the user is on.
  let currentTabId = "";
  const playTab = (id: string) => {
    const data = yamlCache.get(id);
    if (!data) return;
    currentTabId = id;
    if (metaKicker) metaKicker.textContent = data.kicker;
    if (metaLabel) metaLabel.textContent = data.label;
    if (cmdEl) cmdEl.textContent = data.deploy;
    if (diagramTitleEl) diagramTitleEl.textContent = `${id}.topology`;
    deployTimers.forEach(clearTimeout);
    // Refresh YAML pre content (used when toggle reveals it).
    if (yamlTarget) {
      const caret = yamlTarget.querySelector(".caret");
      yamlTarget.firstChild!.textContent = data.yaml;
      if (caret) yamlTarget.appendChild(caret);
    }
    const parsed = parseUsecaseYaml(data.yaml);
    renderDiagram(parsed);
    if (prefersReducedMotion) {
      deploySteps.forEach((el) => el.setAttribute("data-on", "true"));
      return;
    }
    deploySteps.forEach((el) => el.removeAttribute("data-on"));
    [800, 1500, 2300].forEach((d, idx) => {
      deployTimers.push(setTimeout(() => deploySteps[idx]?.setAttribute("data-on", "true"), d));
    });
  };

  // Reset-layout button: re-render the current tab's diagram, restoring
  // every dragged agent to its computed-on-the-ring position. Cheaper
  // than tracking initial positions per agent — renderDiagram already
  // computes them deterministically from slots/ringR/cx/cy.
  const ucReset = document.querySelector<HTMLButtonElement>("[data-diagram-reset]");
  if (ucReset) {
    ucReset.addEventListener("click", () => {
      if (currentTabId) playTab(currentTabId);
    });
  }

  // Show-YAML toggle: flip the diagram container into yaml-mode and back.
  if (ucToggle && ucDiagram) {
    ucToggle.addEventListener("click", () => {
      const showing = ucDiagram.getAttribute("data-show-yaml") === "true";
      const next = !showing;
      ucDiagram.setAttribute("data-show-yaml", String(next));
      ucToggle.setAttribute("aria-pressed", String(next));
      ucToggle.textContent = next ? "show diagram" : "show YAML";
      if (yamlTarget) {
        if (next) yamlTarget.removeAttribute("hidden");
        else yamlTarget.setAttribute("hidden", "");
      }
    });
  }

  // Kick off the first tab without waiting for a click
  const firstTab = document.querySelector<HTMLButtonElement>("[data-tabs] .v2-tab");
  if (firstTab) playTab(firstTab.getAttribute("data-tab")!);

  document.querySelectorAll<HTMLButtonElement>("[data-tabs] .v2-tab").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-tab")!;
      document
        .querySelectorAll<HTMLButtonElement>("[data-tabs] .v2-tab")
        .forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "true");
      playTab(id);
    });
  });

  // Comparison row sweep on intersection — staggered so the table
  // visibly draws itself row-by-row (when all rows enter view together
  // they'd otherwise sweep simultaneously and the cascade is lost).
  const cmpRows = Array.from(
    document.querySelectorAll<HTMLElement>("[data-compare-row]"),
  );
  const cmpIndex = new Map(cmpRows.map((el, i) => [el, i]));
  const cmpIo = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const i = cmpIndex.get(e.target as HTMLElement) ?? 0;
        const delay = prefersReducedMotion ? 0 : i * 70;
        setTimeout(() => {
          (e.target as HTMLElement).setAttribute("data-sweep", "true");
        }, delay);
        cmpIo.unobserve(e.target);
      });
    },
    { threshold: 0.3 }
  );
  cmpRows.forEach((el) => cmpIo.observe(el));
</script>
