    border-color: var(--warm);
    transform: translateY(-2px);
  }
  :root[data-theme] .v2-creator-num {
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-size: 28px;
    font-weight: 600;
    color: var(--warm);
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }

  /* Comparison */
  :root[data-theme] .v2-compare {
    background: var(--bgElev);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  :root[data-theme] .v2-compare-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    border-top: 1px solid var(--lineSoft);
  }
  :root[data-theme] .v2-compare-head {
    background: var(--bgInk);
    border-bottom: 1px solid var(--line);
    border-top: none;
  }
  :root[data-theme] .v2-compare-head > div {
    padding: 14px 18px;
    font-size: 12.5px;
    font-weight: 600;
    text-align: center;
  }
  :root[data-theme] .v2-compare-head > div:first-child {
    font-size: 11px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: left;
    font-weight: 400;
  }
  :root[data-theme] .v2-compare-head .is-us { color: var(--accent); }
  :root[data-theme] .v2-compare-row > div { padding: 14px 18px; font-size: 13.5px; color: var(--ink); }
  :root[data-theme] .v2-compare-row .val { text-align: center; font-size: 13px; }
  :root[data-theme] .v2-compare-row .ok { color: var(--good); font-weight: 600; }
  :root[data-theme] .v2-compare-row .no { color: var(--inkSoft); }
  :root[data-theme] .v2-compare-row .partial { color: var(--warm); font-family: ui-monospace, "JetBrains Mono", monospace; }
  :root[data-theme] .v2-compare-row[data-sweep] {
    background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 30%);
  }

  /* FAQ */
  :root[data-theme] .v2-faq { display: flex; flex-direction: column; gap: 8px; }
  :root[data-theme] .v2-faq-item {
    background: var(--bgElev);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
  }
  :root[data-theme] .v2-faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }
  :root[data-theme] .v2-faq-item summary::-webkit-details-marker { display: none; }
  :root[data-theme] .v2-faq-item .plus {
    color: var(--inkSoft);
    font-size: 22px;
    line-height: 1;
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :root[data-theme] .v2-faq-item[open] .plus { transform: rotate(45deg); }
  :root[data-theme] .v2-faq-a { padding: 0 22px 20px; font-size: 14px; color: var(--inkMid); line-height: 1.6; }

  /* Final */
  :root[data-theme] .v2-final { padding: 96px 32px; text-align: center; }
  :root[data-theme] .v2-final-h2 {
    margin: 0;
    font-size: 48px;
    letter-spacing: -0.025em;
    font-weight: 600;
    line-height: 1.15;
    text-wrap: balance;
  }
  :root[data-theme] .v2-final-p {
    margin: 18px 0 28px;
    font-size: 17px;
    color: var(--inkMid);
    line-height: 1.55;
  }

  /* Footer */
  :root[data-theme] .v2-footer { background: var(--bgInk); padding: 48px 32px 28px; }
  :root[data-theme] .v2-footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 40px;
  }
  :root[data-theme] .v2-footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }
  :root[data-theme] .v2-footer-grid p {
    margin: 0;
    font-size: 13px;
    color: var(--inkMid);
    line-height: 1.6;
    max-width: 320px;
  }
  :root[data-theme] .v2-footer-h {
    font-size: 11px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  :root[data-theme] .v2-footer-grid a {
    display: block;
    font-size: 13px;
    color: var(--inkMid);
    margin-bottom: 8px;
    text-decoration: none;
    cursor: pointer;
  }
  :root[data-theme] .v2-footer-grid a:hover { color: var(--ink); }
  :root[data-theme] .v2-footer-bottom {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Reveal */
  :root[data-theme] [data-reveal] {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :root[data-theme] [data-reveal][data-seen] {
    opacity: 1;
    transform: translateY(0);
  }

  /* Particle canvas */
  :root[data-theme] canvas[data-particle] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Responsive — design targets 1280; provide graceful collapse below. */
  @media (max-width: 1100px) {
    :root[data-theme] .v2-hero-grid { grid-template-columns: 1fr; gap: 32px; }
    :root[data-theme] .v2-grid-4 { grid-template-columns: repeat(2, 1fr); }
    :root[data-theme] .v2-grid-3 { grid-template-columns: 1fr; }
    :root[data-theme] .v2-usecase-grid { grid-template-columns: 1fr; }
    :root[data-theme] .v2-hermes { grid-template-columns: 1fr; gap: 20px; padding: 24px; }
    :root[data-theme] .v2-ships-grid { grid-template-columns: 1fr; }
    :root[data-theme] .v2-h1 { font-size: 44px; }
    :root[data-theme] .v2-final-h2 { font-size: 36px; }
    :root[data-theme] .v2-footer-grid { grid-template-columns: 1fr 1fr; }
    :root[data-theme] .v2-stat-row { flex-wrap: wrap; }
  }
  @media (max-width: 640px) {
    :root[data-theme] .v2-section { padding: 56px 20px; }
    :root[data-theme] .v2-grid-4 { grid-template-columns: 1fr; }
    :root[data-theme] .v2-statusbar { display: none; }
    :root[data-theme] .v2-nav-links { display: none; }
    :root[data-theme] .v2-h1 { font-size: 36px; }
    :root[data-theme] .v2-h2 { font-size: 22px; }
    :root[data-theme] .v2-section-head { flex-direction: column; align-items: flex-start; }
    :root[data-theme] .v2-compare-row { grid-template-columns: 1.3fr 0.8fr 0.8fr 0.8fr 0.8fr; }
    :root[data-theme] .v2-compare-row > div { padding: 10px 12px; font-size: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    :root[data-theme] [data-reveal] { opacity: 1; transform: none; transition: none; }
    :root[data-theme] .v2-marquee-track { animation: none; }
    :root[data-theme] .v2-h1-shimmer {
      animation: none;
      background: var(--accent);
      -webkit-background-clip: text;
      background-clip: text;
    }
  }
</style>

<script>
  // Reveal observer
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          const delay = parseInt(el.getAttribute("data-delay") || "0", 10);
          setTimeout(() => el.setAttribute("data-seen", "true"), delay);
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

  // Counters
  const counterIo = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const to = parseInt(el.getAttribute("data-counter") || "0", 10);
        const suffix = el.getAttribute("data-suffix") || "";
        const start = performance.now();
        const dur = 1400;
        const step = (now: number) => {
          const k = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - k, 3);
          el.textContent = Math.round(eased * to).toLocaleString() + suffix;
          if (k < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
        counterIo.unobserve(e.target);
      });
    },
    { threshold: 0.4 }
  );
  document.querySelectorAll("[data-counter]").forEach((el) => counterIo.observe(el));

  // A2A live counter
  const a2a = document.querySelector("[data-a2a]");
  if (a2a) {
    setInterval(() => {
      a2a.textContent = String(40 + Math.floor(Math.random() * 18));
    }, 1200);
  }

  // Particle field — read theme tokens at draw time so the canvas
  // matches whatever data-theme the boot script resolved. Doesn't
  // re-init on toggle (decorative) — full redraw on next nav.
  const styles = getComputedStyle(document.body);
  const accent = styles.getPropertyValue("--accent").trim() || "#3b5bdb";
  const warm = styles.getPropertyValue("--warm").trim() || "#c0532b";
  document.querySelectorAll("canvas[data-particle]").forEach((cvs) => {
    const c = cvs as HTMLCanvasElement;
    const ctx = c.getContext("2d");
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const density = parseFloat(c.getAttribute("data-density") || "0.00009");
    const lineDist = parseInt(c.getAttribute("data-line") || "110", 10);
    const isWarm = c.getAttribute("data-color") === "warm";
    const color = isWarm ? warm : accent;
    let parts: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
    let w = 0,
      h = 0,
      raf = 0;
    const resize = () => {
      const r = c.getBoundingClientRect();
      w = r.width;
      h = r.height;
      c.width = w * dpr;
      c.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = Math.max(28, Math.floor(w * h * density));
      parts = Array.from({ length: n }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.18,
        vy: (Math.random() - 0.5) * 0.18,
        r: 1 + Math.random() * 1.5,
      }));
    };
    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < parts.length; i++) {
        for (let j = i + 1; j < parts.length; j++) {
          const a = parts[i],
            b = parts[j];
          const dx = a.x - b.x,
            dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < lineDist * lineDist) {
            const k = 1 - Math.sqrt(d2) / lineDist;
            ctx.strokeStyle = `color-mix(in srgb, ${color} ${(k * 35).toFixed(1)}%, transparent)`;
            ctx.lineWidth = 0.6;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
      ctx.fillStyle = `color-mix(in srgb, ${color} 55%, transparent)`;
      parts.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      });
      raf = requestAnimationFrame(draw);
    };
    resize();
    draw();
    const ro = new ResizeObserver(resize);
    ro.observe(c);
  });

  // Live topology with breathing nodes + animated A2A packet streams
  const tSvg = document.querySelector("svg[data-topology]") as SVGSVGElement | null;
  if (tSvg) {
    const w = 560,
      h = 420;
    const root = { x: w / 2, y: 70, label: "CEO Coordinator" };
    const mids = [
      { x: 130, y: 200, label: "Engineering" },
      { x: 280, y: 200, label: "Compliance" },
      { x: 430, y: 200, label: "Finance" },
    ];
    const leaves = [
      { x: 60, y: 340, p: 0, label: "SWE" },
      { x: 130, y: 340, p: 0, label: "QA" },
      { x: 200, y: 340, p: 0, label: "DevRel" },
      { x: 280, y: 340, p: 1, label: "Audit" },
      { x: 360, y: 340, p: 1, label: "Risk" },
      { x: 430, y: 340, p: 2, label: "Books" },
      { x: 500, y: 340, p: 2, label: "Tax" },
    ];
    const svgNs = "http://www.w3.org/2000/svg";
    const defs = document.createElementNS(svgNs, "defs");
    const dotColor = styles.getPropertyValue("--line").trim() || "#e6e2d8";
    defs.innerHTML = `
      <pattern id="lt-dots" width="22" height="22" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="${dotColor}"/>
      </pattern>
      <radialGradient id="lt-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="${accent}" stop-opacity="0.6"/>
        <stop offset="100%" stop-color="${accent}" stop-opacity="0"/>
      </radialGradient>`;
    tSvg.appendChild(defs);
    const bg = document.createElementNS(svgNs, "rect");
    bg.setAttribute("width", String(w));
    bg.setAttribute("height", String(h));
    bg.setAttribute("fill", "url(#lt-dots)");
    tSvg.appendChild(bg);

    const edges = document.createElementNS(svgNs, "g");
    tSvg.appendChild(edges);
    const nodes = document.createElementNS(svgNs, "g");
    tSvg.appendChild(nodes);
    const pktLayer = document.createElementNS(svgNs, "g");
    tSvg.appendChild(pktLayer);

    const ink = styles.getPropertyValue("--ink").trim() || "#15181c",
      inkMid = styles.getPropertyValue("--inkMid").trim() || "#5a5e66",
      bgElev = styles.getPropertyValue("--bgElev").trim() || "#ffffff";

    const drawNode = (
      x: number,
      y: number,
      label: string,
      opts: { root?: boolean; small?: boolean }
    ) => {
      const baseR = opts.root ? 24 : opts.small ? 14 : 18;
      const g = document.createElementNS(svgNs, "g");
      const ring = document.createElementNS(svgNs, "circle");
      ring.setAttribute("cx", String(x));
      ring.setAttribute("cy", String(y));
      ring.setAttribute("r", "0");
      ring.setAttribute("fill", "none");
      ring.setAttribute("stroke", accent);
      ring.setAttribute("stroke-width", "1.2");
      g.appendChild(ring);
      const outer = document.createElementNS(svgNs, "circle");
      outer.setAttribute("cx", String(x));
      outer.setAttribute("cy", String(y));
      outer.setAttribute("r", String(baseR));
      outer.setAttribute("fill", bgElev);
      outer.setAttribute("stroke", ink);
      outer.setAttribute("stroke-width", "1");
      g.appendChild(outer);
      const inner = document.createElementNS(svgNs, "circle");
      inner.setAttribute("cx", String(x));
      inner.setAttribute("cy", String(y));
      inner.setAttribute("r", String(baseR - 7));
      inner.setAttribute("fill", opts.root ? ink : inkMid);
      if (opts.small) inner.setAttribute("opacity", "0.55");
      g.appendChild(inner);
      const tx = document.createElementNS(svgNs, "text");
      tx.setAttribute("x", String(x));
      tx.setAttribute("y", String(y + baseR + 14));
      tx.setAttribute("text-anchor", "middle");
      tx.setAttribute("font-size", "10");
      tx.setAttribute("font-family", "ui-monospace, monospace");
      tx.setAttribute("fill", inkMid);
      tx.textContent = label;
      g.appendChild(tx);
      nodes.appendChild(g);
      return { ring, outer, inner, baseR };
    };

    mids.forEach((m) => {
      const ln = document.createElementNS(svgNs, "line");
      ln.setAttribute("x1", String(root.x));
      ln.setAttribute("y1", String(root.y));
      ln.setAttribute("x2", String(m.x));
      ln.setAttribute("y2", String(m.y));
      ln.setAttribute("stroke", ink);
      ln.setAttribute("stroke-opacity", "0.22");
      ln.setAttribute("stroke-width", "1");
      edges.appendChild(ln);
    });
    const leafEdges = leaves.map((l) => {
      const m = mids[l.p];
      const ln = document.createElementNS(svgNs, "line");
      ln.setAttribute("x1", String(m.x));
      ln.setAttribute("y1", String(m.y));
      ln.setAttribute("x2", String(l.x));
      ln.setAttribute("y2", String(l.y));
      ln.setAttribute("stroke", ink);
      ln.setAttribute("stroke-opacity", "0.18");
      ln.setAttribute("stroke-width", "1");
      edges.appendChild(ln);
      return ln;
    });

    const rootN = drawNode(root.x, root.y, root.label, { root: true });
    const midNs = mids.map((m) => drawNode(m.x, m.y, m.label, {}));
    const leafNs = leaves.map((l) => drawNode(l.x, l.y, l.label, { small: true }));

    const pkts = [0, 0.33, 0.66].map(() => {
      const g = document.createElementNS(svgNs, "g");
      const halo = document.createElementNS(svgNs, "circle");
      halo.setAttribute("r", "14");
      halo.setAttribute("fill", "url(#lt-glow)");
      g.appendChild(halo);
      const dot = document.createElementNS(svgNs, "circle");
      dot.setAttribute("r", "3.5");
      dot.setAttribute("fill", accent);
      g.appendChild(dot);
      pktLayer.appendChild(g);
      return { g, halo, dot };
    });

    const animate = () => {
      const time = performance.now() / 1000;
      [rootN, ...midNs, ...leafNs].forEach((n, i) => {
        const breathe = Math.sin(time * 1.4 + i * 0.3) * 1.2;
        n.outer.setAttribute("r", String(n.baseR + breathe * 0.4));
      });
      const streams = [0, 0.33, 0.66].map((off) => {
        const phase = ((time * 0.45) + off) % 1;
        const idx = Math.floor((time * 0.45 + off) % leaves.length);
        return { phase, idx: idx % leaves.length };
      });
      leafEdges.forEach((ln, i) => {
        const hot = streams.some((s) => s.idx === i);
        ln.setAttribute("stroke", hot ? accent : ink);
        ln.setAttribute("stroke-opacity", hot ? "0.85" : "0.18");
        ln.setAttribute("stroke-width", hot ? "1.6" : "1");
      });
      leafNs.forEach((n, i) => {
        const active = streams.some((s) => s.idx === i);
        if (active) {
          const ringR = n.baseR + 6 + (Math.sin(time * 2 + i * 0.2) * 0.5 + 0.5) * 8;
          const ringO = Math.max(0, 0.7 - (Math.sin(time * 2 + i * 0.2) * 0.5 + 0.5) * 0.7);
          n.ring.setAttribute("r", String(ringR));
          n.ring.setAttribute("stroke-opacity", String(ringO));
          n.outer.setAttribute("stroke", accent);
          n.outer.setAttribute("stroke-width", "2");
          n.inner.setAttribute("fill", accent);
        } else {
          n.ring.setAttribute("r", "0");
          n.outer.setAttribute("stroke", ink);
          n.outer.setAttribute("stroke-width", "1");
          n.inner.setAttribute("fill", inkMid);
        }
      });
      streams.forEach((s, i) => {
        const target = leaves[s.idx];
        const m = mids[target.p];
        const p = s.phase;
        let x: number, y: number;
        if (p < 0.5) {
          const k = p / 0.5;
          x = root.x + (m.x - root.x) * k;
          y = root.y + (m.y - root.y) * k;
        } else {
          const k = (p - 0.5) / 0.5;
          x = m.x + (target.x - m.x) * k;
          y = m.y + (target.y - m.y) * k;
        }
        pkts[i].halo.setAttribute("cx", String(x));
        pkts[i].halo.setAttribute("cy", String(y));
        pkts[i].dot.setAttribute("cx", String(x));
        pkts[i].dot.setAttribute("cy", String(y));
      });
      requestAnimationFrame(animate);
    };
    requestAnimationFrame(animate);
  }

  // Use case tabs (typewriter + deploy steps)
  type Cache = { yaml: string; kicker: string; label: string; deploy: string };
  const yamlCache = new Map<string, Cache>();
  document.querySelectorAll<HTMLScriptElement>("script[data-yaml]").forEach((el) => {
    const id = el.getAttribute("data-yaml")!;
    try {
      yamlCache.set(id, JSON.parse(el.textContent || "{}"));
    } catch {
      // ignore
    }
  });
  const yamlTarget = document.querySelector<HTMLPreElement>("[data-yaml-target]");
  const metaKicker = document.querySelector<HTMLElement>("[data-meta-kicker]");
  const metaLabel = document.querySelector<HTMLElement>("[data-meta-label]");
  const cmdEl = document.querySelector<HTMLElement>("[data-cmd]");
  const deploySteps = document.querySelectorAll<HTMLElement>("[data-deploy] .v2-deploy-step");
  let typeIv: ReturnType<typeof setInterval> | null = null;
  let deployTimers: ReturnType<typeof setTimeout>[] = [];

  const playTab = (id: string) => {
    const data = yamlCache.get(id);
    if (!data || !yamlTarget) return;
    if (metaKicker) metaKicker.textContent = data.kicker;
    if (metaLabel) metaLabel.textContent = data.label;
    if (cmdEl) cmdEl.textContent = data.deploy;
    if (typeIv) clearInterval(typeIv);
    const target = data.yaml;
    let i = 0;
    const speed = Math.max(2, Math.floor(target.length / 60));
    yamlTarget.firstChild!.textContent = "";
    typeIv = setInterval(() => {
      i += speed;
      if (i >= target.length) {
        yamlTarget.firstChild!.textContent = target;
        if (typeIv) clearInterval(typeIv);
      } else {
        yamlTarget.firstChild!.textContent = target.slice(0, i);
      }
    }, 16);
    deployTimers.forEach(clearTimeout);
    deploySteps.forEach((el) => el.removeAttribute("data-on"));
    [800, 1500, 2300].forEach((d, idx) => {
      deployTimers.push(setTimeout(() => deploySteps[idx]?.setAttribute("data-on", "true"), d));
    });
  };

  // Kick off the first tab without waiting for a click
  const firstTab = document.querySelector<HTMLButtonElement>("[data-tabs] .v2-tab");
  if (firstTab) playTab(firstTab.getAttribute("data-tab")!);

  document.querySelectorAll<HTMLButtonElement>("[data-tabs] .v2-tab").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-tab")!;
      document
        .querySelectorAll<HTMLButtonElement>("[data-tabs] .v2-tab")
        .forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "true");
      playTab(id);
    });
  });

  // Comparison row sweep on intersection
  const cmpIo = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).setAttribute("data-sweep", "true");
          cmpIo.unobserve(e.target);
        }
      });
    },
    { threshold: 0.3 }
  );
  document
    .querySelectorAll("[data-compare-row]")
    .forEach((el) => cmpIo.observe(el));
</script>
