  /* Topology label (CEO Coordinator, Engineering, etc.) inside the
     hero card SVG. The JS draws these via createElementNS and caches
     getComputedStyle once at load — that means the resolved hex from
     the FIRST theme is baked into the fill attribute. CSS rule here
     overrides the attribute so the label stays theme-reactive after
     a toggle. */
  :root[data-theme] svg[data-topology] .v2-topo-label {
    fill: var(--inkMid);
