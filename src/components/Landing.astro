<style is:global>
  /* Token values per theme. Selectors are gated on :root[data-theme]
   * (matches <html>) so the cascade resolves against the attribute
   * the boot script in Layout.astro stamps synchronously — before
   * <body> exists. Stamping body would FOUC the first paint frame
   * because body wouldn't carry the resolved theme until
   * DOMContentLoaded. Shadow components use --shadow-rgb so elevation
   * darkens correctly on cream paper but shifts to true black on
   * deep ink.
   */
  :root[data-theme="light"] {
    --bg: #fafaf7;
    --bgElev: #ffffff;
    --bgInk: #f3f1ec;
    --line: #e6e2d8;
    --lineSoft: #efece4;
    --ink: #15181c;
    --inkMid: #5a5e66;
    --inkSoft: #6c6e74;  /* WCAG AA on cream bg: 4.9:1 (was #8b8e95 = 3.2:1, failed). */
    --accent: #3b5bdb;
    --accentInk: #1a2f99;
    --warm: #c0532b;
    --good: #2f7a4d;
    --shadow-rgb: 21, 24, 28;
    --accent-fg: #ffffff;     /* text on --accent surfaces */
  }
  :root[data-theme="dark"] {
    --bg: #050912;
    --bgElev: #0d1729;
    --bgInk: #0a1120;
    --line: #13263f;
    --lineSoft: #1c3350;
    --ink: #e5f0ff;
    --inkMid: #8fa3bf;
    --inkSoft: #7a8fae;  /* WCAG AA on dark bg: 6.0:1 (was #5f7691 = 4.2:1, failed). */
    --accent: #7fe8d6;       /* mint accent in dark */
    --accentInk: #a8f0e1;
    --warm: #ffd166;
    --good: #6af0b8;
    --shadow-rgb: 0, 0, 0;
    --accent-fg: #04121a;     /* dark text on pale-mint accent */
  }
  :root[data-theme] body {
    margin: 0;
    font-family: "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    background: var(--bg);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    background-image: none;
  }
  :root[data-theme] *,
  :root[data-theme] *::before,
  :root[data-theme] *::after {
    box-sizing: border-box;
  }
  :root[data-theme] .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    margin-right: 6px;
  }
  :root[data-theme] .dot-good { background: var(--good); color: var(--good); }
  :root[data-theme] .dot-warm { background: var(--warm); color: var(--warm); }
  :root[data-theme] .dot-accent { background: var(--accent); color: var(--accent); opacity: 0.5; }
  :root[data-theme] .pulsing {
    animation: v2-pulse 1.4s ease-out infinite;
  }
  @keyframes v2-pulse {
    0% { box-shadow: 0 0 0 0 currentColor; }
    70% { box-shadow: 0 0 0 6px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* Override the legacy mol-skip-link from globals.css to fit the light theme. */
  :root[data-theme] .mol-skip-link {
    background: var(--accent);
    color: var(--accent-fg);
  }

  /* Scroll-progress indicator — pinned to viewport top, fills with
     accent as the user scrolls. Modern browsers use CSS scroll-driven
     animation (animation-timeline: scroll(root)); older browsers fall
     through to JS-driven width via the small block in scripts/site.ts. */
  .v2-scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    z-index: 100;
    pointer-events: none;
    transform-origin: left center;
    will-change: width, transform;
  }
  @supports (animation-timeline: scroll(root)) {
    .v2-scroll-progress {
      width: 100%;
      transform: scaleX(0);
      animation: v2-scroll-progress-fill auto linear both;
      animation-timeline: scroll(root);
    }
    @keyframes v2-scroll-progress-fill {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  }

  /* Back-to-top button — fixed bottom-right, appears after the user
     has scrolled ~600px (past the hero). Modern browsers use the
     scroll-driven animation primitive to fade in; older browsers
     fall through to a JS scroll listener that toggles a class. */
  .v2-back-to-top {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, background 0.18s ease;
    z-index: 90;
    box-shadow: 0 8px 24px -8px rgba(var(--shadow-rgb), 0.25);
  }
  .v2-back-to-top:hover {
    background: var(--accent);
    color: var(--accent-fg);
  }
  .v2-back-to-top:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  /* Modern: scroll-timeline keyframe shows the button after ~600px
     of scroll. CSS-only show/hide, no JS. */
  @supports (animation-timeline: scroll(root)) {
    .v2-back-to-top {
      animation: v2-back-to-top-show linear both;
      animation-timeline: scroll(root);
      animation-range: 600px 800px;
    }
    @keyframes v2-back-to-top-show {
      from { opacity: 0; pointer-events: none; transform: translateY(8px); }
      to { opacity: 1; pointer-events: auto; transform: translateY(0); }
    }
  }
  /* JS-fallback class for older browsers — scripts/site.ts equivalent
     toggles this class on scroll. */
  .v2-back-to-top[data-shown="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* Nav */
  :root[data-theme] .v2-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  :root[data-theme] .v2-statusbar {
    background: var(--bgInk);
    border-bottom: 1px solid var(--lineSoft);
    padding: 5px 32px;
    font-size: 11px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  :root[data-theme] .v2-status-link {
    color: var(--inkMid);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--inkMid) 35%, transparent);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  :root[data-theme] .v2-status-link:hover {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }
  /* Status link is the first tab stop on the page and sits on the
     darkest surface (--bgInk), where the default browser focus ring
     is effectively invisible. Match the PR #135 footer pattern so
     keyboard users land on a clearly outlined target before the
     locale + nav row even comes into focus. */
  :root[data-theme] .v2-status-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
  :root[data-theme] .v2-nav-row {
    max-width: 1320px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  :root[data-theme] .v2-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }
  /* Tactile micro-feedback on the brand-mark SVG when the user hovers
     the logo: a small rotation + slight scale so the brand reads as a
     clickable, responsive element. The mark is a 3-node topology — a
     subtle nudge reinforces the "topology IS your config" theme without
     becoming a stunt animation. Honors prefers-reduced-motion. */
  :root[data-theme] .v2-brand svg {
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
      color 0.25s ease;
    transform-origin: 50% 50%;
    will-change: transform;
  }
  :root[data-theme] .v2-brand:hover svg {
    transform: rotate(8deg) scale(1.06);
    color: var(--accent);
  }
  :root[data-theme] .v2-brand:hover .v2-brand-name {
    color: var(--accent);
  }
  :root[data-theme] .v2-brand-name {
    transition: color 0.25s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    :root[data-theme] .v2-brand svg {
      transition: color 0.25s ease;
    }
    :root[data-theme] .v2-brand:hover svg {
      transform: none;
    }
  }
  :root[data-theme] .v2-brand-name { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; }
  :root[data-theme] .v2-brand-tag {
    font-size: 11px;
    color: var(--inkSoft);
    font-family: ui-monospace, "JetBrains Mono", monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  :root[data-theme] .v2-nav-links {
    display: flex;
    gap: 22px;
    font-size: 13px;
    color: var(--inkMid);
  }
  :root[data-theme] .v2-nav-links a {
    cursor: pointer;
    color: inherit;
    text-decoration: none;
    /* Grow-from-left underline on hover. Pseudo-element so the link
       text doesn't shift when the underline appears. transition on
       transform's scaleX is GPU-accelerated and crisp at any zoom. */
    position: relative;
    transition: color 0.18s ease;
  }
  :root[data-theme] .v2-nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.22s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :root[data-theme] .v2-nav-links a:hover { color: var(--ink); }
  :root[data-theme] .v2-nav-links a:hover::after,
  :root[data-theme] .v2-nav-links a:focus-visible::after {
    transform: scaleX(1);
  }
  /* Scroll-spy active state — IntersectionObserver in site.ts toggles
     [data-active] on the link whose section is in view. Mirrors the
     :hover state so it reads "you are here". */
  :root[data-theme] .v2-nav-links a[data-active] { color: var(--ink); }
  :root[data-theme] .v2-nav-links a[data-active]::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    :root[data-theme] .v2-nav-links a[data-active]::after {
      transition: none;
    }
  }
  :root[data-theme] .v2-nav-cta { display: flex; gap: 8px; align-items: center; }

  /* Locale dropdown — native <details> for click-out + a11y. */
  :root[data-theme] .v2-locale {
    position: relative;
