  :root[data-theme] .v2-hero-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 40px 80px -28px rgba(var(--shadow-rgb), 0.22),
      0 0 80px -16px color-mix(in srgb, var(--accent) 38%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    :root[data-theme] .v2-hero-card,
    :root[data-theme] .v2-hero-card:hover {
