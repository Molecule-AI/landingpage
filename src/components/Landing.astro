  :root[data-theme] .v2-cta-row { display: flex; gap: 10px; margin-bottom: 32px; }
  :root[data-theme] .v2-cta-center { justify-content: center; margin-bottom: 0; }
  :root[data-theme] .v2-stat-row {
    display: flex;
    gap: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    color: var(--inkSoft);
