---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SocialProof from "../components/SocialProof.astro";
import WhyNow from "../components/WhyNow.astro";
import UseCases from "../components/UseCases.astro";
import Architecture from "../components/Architecture.astro";
import Adapters from "../components/Adapters.astro";
import Platform from "../components/Platform.astro";
import WhatShips from "../components/WhatShips.astro";
import WhyMolecule from "../components/WhyMolecule.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";

const locale = "en" as const;
---

<Layout locale={locale}>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <SocialProof locale={locale} />
    <WhyNow locale={locale} />
    <UseCases locale={locale} />
    <Architecture locale={locale} />
    <Adapters locale={locale} />
    <WhatShips locale={locale} />
    <Platform locale={locale} />
    <WhyMolecule locale={locale} />
    <FinalCTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
