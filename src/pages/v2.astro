---
// New landing design — warm-paper light theme + governance-blue accent.
// Ported from Molecule Landing.html design bundle (Claude Design handoff).
// Lives at /v2 for review. The current dark/mint landing remains at /.

const runtimes = [
  "LangGraph",
  "Claude Code",
  "CrewAI",
  "AutoGen",
  "DeepAgents",
  "Hermes",
  "Gemini CLI",
  "OpenClaw",
  "LangChain",
  "Pydantic AI",
  "Bedrock Agents",
  "Vercel AI",
];

const reasons = [
  {
    k: "01",
    title: "Agent count is exploding",
    body: "Teams have 1 agent today, 10+ next year. The bottleneck is no longer the model — it's how agents coordinate.",
  },
  {
    k: "02",
    title: "A2A & MCP became standards",
    body: "Cross-agent protocols are stabilizing. Multi-agent stops being an engineering problem and becomes a product problem.",
  },
  {
    k: "03",
    title: "Governance is now a buying gate",
    body: "EU AI Act, OWASP Agentic Top 10. Audit, HITL, RBAC are no longer optional.",
  },
  {
    k: "04",
    title: "Runtimes are commoditizing",
    body: "Every quarter, a new \"best\" runtime ships. The platform layer wins — runtime-portable is the only safe bet.",
  },
];

const useCases = [
  {
    id: "fintech",
    label: "Fintech · Series A",
    kicker: "9 agents · 14 plugins",
    yaml: `org: fintech-startup
agents:
  - role: cfo
    runtime: langgraph
    tools: [ledger, stripe]
  - role: compliance
    runtime: claude-code
    plugins: [eu-ai-act, owasp-top-10]
  - role: senior-swe
    runtime: claude-code
    plugins: [pr-7gate, review-16d]
hitl:
  - amount > 10_000 → dual_review`,
  },
  {
    id: "soc",
    label: "Security Ops Center",
    kicker: "8 agents · 21 plugins",
    yaml: `org: soc-team
agents:
  - role: l1-triage
    runtime: hermes
  - role: l2-investigator
    runtime: deepagents
    tools: [virustotal, mitre]
  - role: l3-analyst
    runtime: claude-code
  - role: ir-lead
    runtime: langgraph
hitl:
  - severity >= high → l3 + ir-lead`,
  },
  {
    id: "lab",
    label: "Research Lab",
    kicker: "6 agents · 9 plugins",
    yaml: `org: med-research-lab
agents:
  - role: pi
    runtime: langgraph
  - role: postdoc
    count: 2
    runtime: deepagents
    tools: [pubmed, cochrane]
  - role: stats
    runtime: claude-code
  - role: irb-liaison
    runtime: hermes
memory:
  global: { scope: lab-corpus }`,
  },
  {
    id: "creator",
    label: "Solo creator",
    kicker: "4 agents · 8 plugins",
    yaml: `org: creator-studio
agents:
  - role: editor
    runtime: claude-code
  - role: researcher
    runtime: deepagents
  - role: social
    runtime: hermes
    tools: [twitter, linkedin]
  - role: analytics
    runtime: langgraph`,
  },
];

const pillars = [
  { k: "F1", title: "Role > Task", body: "Model the org chart, not the workflow. Roles inherit tools, memory scope, HITL ladder." },
  { k: "F2", title: "Recursive teams", body: "Agents can spin up sub-teams within their permission envelope. Org grows like a living tree." },
  { k: "F3", title: "Org = Topology", body: "Every workspace is a versioned graph. Diff it, branch it, share it, sell it." },
  { k: "F4", title: "Distributed A2A", body: "Agents speak JSON-RPC 2.0 directly. Platform routes; never a single bottleneck." },
  { k: "F5", title: "4-layer security", body: "Identity · permission · audit · encryption. AES-256-GCM envelopes, WorkOS OAuth." },
  { k: "F6", title: "Tiered HITL", body: "No-approval, single-reviewer, dual-reviewer. Risk-graded, configured per role." },
  { k: "F7", title: "Cross-workspace traces", body: "OpenTelemetry + Langfuse — every call across every agent, in one timeline." },
  { k: "F8", title: "3-layer Marketplace", body: "Plugin · Agent · Org. Two layers more than GitHub Actions, two more than GPT Store." },
];

const tiers = [
  {
    tag: "L1",
    title: "Plugin",
    desc: "A tool, guardrail, or compliance hook. Plug into any agent.",
    count: "21 first-party · open to third parties soon",
    glyph: "plugin",
  },
  {
    tag: "L2",
    title: "Agent",
    desc: "A pre-trained role: tax CPA, SOC analyst, PM, QA. Hire, don't train.",
    count: "8 verified roles in beta",
    glyph: "agent",
  },
  {
    tag: "L3",
    title: "Org Bundle",
    desc: "A whole department: agents, plugins, topology, HITL ladder.",
    count: "6 templates published",
    glyph: "org",
  },
];

const compareCols = ["Molecule", "Agent frameworks", "LLM Ops", "Workflow tools"];
const compareRows: [string, string, string, string, string][] = [
  ["Multi-agent topology, native", "✓", "—", "✓", "partial"],
  ["Runtime-portable", "✓", "runtime-locked", "—", "—"],
  ["A2A protocol", "✓", "—", "—", "—"],
  ["Three-tier marketplace", "✓", "—", "—", "—"],
  ["Audit trail · EU AI Act ready", "✓", "partial", "—", "partial"],
  ["HITL tiers", "✓", "—", "—", "partial"],
  ["Org template versioning", "✓", "—", "—", "—"],
];

const faqs: [string, string][] = [
  [
    "Why not just use one super-agent?",
    "Context pollution and hallucination compound. Specialized agents in their own context windows is how every large organization in human history has worked — and how language models stay sharp.",
  ],
  [
    "What if a better runtime ships next year?",
    "Swap it. Roles, memory, and topology are abstract. Adapters connect runtimes; nothing in your config changes when you migrate.",
  ],
  [
    "How does the marketplace work for sellers?",
    "Three tiers: Plugin, Agent, Org. Set your price, ship a signed manifest, get paid via Stripe Connect. We take 20%.",
  ],
  [
    "Self-hosted?",
    "Yes — full private deployment with the same Control Plane. Common for regulated industries; data never leaves your tenant.",
  ],
  [
    "What protocols do you support?",
    "A2A (JSON-RPC 2.0) for inter-agent calls, MCP for tool exposure, OpenTelemetry for traces.",
  ],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>Molecule AI — The OS for AI agent organizations</title>
    <meta
      name="description"
      content="Compose multi-agent teams the way you'd staff a company. Visual org topology, A2A protocol, three-tier memory, runtime-portable."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-v2>
    <header class="v2-nav">
      <div class="v2-statusbar">
        <span><i class="dot"></i>All systems · status.moleculesai.app</span>
        <span>Phase 33 shipped · Phase 35 Marketplace public beta</span>
      </div>
      <div class="v2-nav-row">
        <a class="v2-brand" href="/v2">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="6" r="2.5" fill="currentColor" />
            <circle cx="6" cy="20" r="2.5" fill="currentColor" />
            <circle cx="22" cy="20" r="2.5" fill="currentColor" />
            <circle cx="14" cy="14" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2" />
            <line x1="14" y1="8.5" x2="14" y2="12.6" stroke="currentColor" stroke-width="1.2" />
            <line x1="8" y1="18.5" x2="12.7" y2="14.8" stroke="currentColor" stroke-width="1.2" />
            <line x1="20" y1="18.5" x2="15.3" y2="14.8" stroke="currentColor" stroke-width="1.2" />
          </svg>
          <span class="v2-brand-name">Molecule</span>
          <span class="v2-brand-tag">AI</span>
        </a>
        <nav class="v2-nav-links">
          <a>Platform</a>
          <a href="#marketplace">Marketplace</a>
          <a>Runtimes</a>
          <a href="https://docs.moleculesai.app">Docs</a>
          <a href="/pricing">Pricing</a>
          <a>Company</a>
        </nav>
        <div class="v2-nav-cta">
          <a class="v2-btn v2-btn-ghost" href="https://app.moleculesai.app">Sign in</a>
          <a class="v2-btn v2-btn-primary" href="https://app.moleculesai.app">Open Canvas</a>
        </div>
      </div>
    </header>

    <main>
      {/* HERO */}
      <section class="v2-section v2-hero">
        <canvas data-particle data-density="0.00006" data-line="120"></canvas>
        <div class="v2-container v2-hero-grid">
          <div>
            <div class="v2-eyebrow" data-reveal>
              <span class="dot dot-warm"></span>
              Phase 35 · Marketplace public beta is live
            </div>
            <h1 class="v2-h1" data-reveal data-delay="80">
              The operating system for<br />
              <span class="v2-h1-shimmer">AI agent organizations.</span>
            </h1>
            <p class="v2-lede" data-reveal data-delay="160">
              Compose multi-agent teams the way you'd staff a company. Visual
              org topology, A2A protocol, three-tier memory, runtime-portable —
              and a marketplace to buy or sell tools, agents, and entire
              departments.
            </p>
            <div class="v2-cta-row" data-reveal data-delay="240">
              <a class="v2-btn v2-btn-primary v2-btn-lg" href="#marketplace"
                >Explore the Marketplace →</a
              >
              <a class="v2-btn v2-btn-ghost v2-btn-lg" href="mailto:founders@moleculesai.app"
                >Talk to founders</a
              >
            </div>
            <div class="v2-stat-row" data-reveal data-delay="320">
              <div>
                <span class="v2-counter" data-counter="2452" data-suffix="+">0</span>
                <em>tests</em>
              </div>
              <div>
                <span class="v2-counter" data-counter="8">0</span>
                <em>runtimes</em>
              </div>
              <div>
                <span class="v2-counter" data-counter="80" data-suffix="+">0</span>
                <em>API endpoints</em>
              </div>
              <div>
                <span class="v2-counter" data-counter="33">0</span>
                <em>phases shipped</em>
              </div>
            </div>
          </div>
          <div class="v2-hero-card" data-reveal data-delay="120">
            <div class="v2-hero-card-chrome">
              <span>tenant.moleculesai.app/canvas</span>
              <span><i class="dot dot-good pulsing"></i>A2A live · <span data-a2a>42</span> calls/s</span>
            </div>
            <svg
              data-topology
              viewBox="0 0 560 420"
              width="100%"
              style="display:block"
            ></svg>
          </div>
        </div>
      </section>

      {/* LOGO STRIP */}
      <section class="v2-section v2-logo-strip">
        <div class="v2-logo-eyebrow">
          Runtime-neutral · 8 supported, infinitely extensible
        </div>
        <div class="v2-marquee">
          <div class="v2-marquee-track">
            {[...runtimes, ...runtimes].map((n) => (
              <span class="v2-marquee-item">
                <i class="dot dot-accent"></i>
                {n}
              </span>
            ))}
          </div>
        </div>
      </section>

      {/* WHY NOW */}
      <section class="v2-section">
        <div class="v2-container">
          <div class="v2-section-head" data-reveal>
            <div class="v2-kicker">Why now</div>
            <h2 class="v2-h2">Four shifts converging on multi-agent.</h2>
          </div>
          <div class="v2-grid-4">
            {reasons.map((r, i) => (
              <div class="v2-card v2-card-hover" data-reveal data-delay={i * 90}>
                <div class="v2-keynum">{r.k}</div>
                <h3 class="v2-card-title">{r.title}</h3>
                <p class="v2-card-body">{r.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* USE CASES */}
      <section class="v2-section v2-section-ink">
        <div class="v2-container">
          <div class="v2-section-head" data-reveal>
            <div class="v2-kicker">Use cases</div>
            <h2 class="v2-h2">One platform, many shapes.</h2>
          </div>
          <div class="v2-tabs" data-tabs role="tablist" data-reveal data-delay="80">
            {useCases.map((c, i) => (
              <button
                class="v2-tab"
                data-tab={c.id}
                data-active={i === 0 ? "true" : undefined}
                type="button"
              >
                {c.label}
              </button>
            ))}
          </div>
          <div class="v2-usecase-grid" data-reveal data-delay="160">
            <div class="v2-usecase-meta">
              <div class="v2-kicker v2-kicker-accent" data-meta-kicker>
                {useCases[0].kicker}
              </div>
              <h3 class="v2-usecase-h3" data-meta-label>{useCases[0].label}</h3>
              <p class="v2-card-body">
                Defined as code. Versionable. Forkable.
                Marketplace-publishable. The same workspace.yml ships to dev,
                staging, and prod with the topology intact.
              </p>
              <div class="v2-cmd" data-cmd>$ molecule deploy ./fintech.yml</div>
              <div class="v2-deploy-steps" data-deploy>
                <div class="v2-deploy-step"><span class="check">✓</span><em>topology validated</em></div>
                <div class="v2-deploy-step"><span class="check">✓</span><em>agents provisioned</em></div>
                <div class="v2-deploy-step"><span class="check">✓</span><em>A2A routes live</em></div>
              </div>
            </div>
            <div class="v2-yaml">
              <div class="v2-yaml-chrome">
                <span>workspace.yml</span>
                <span class="dots"><i></i><i></i><i></i></span>
              </div>
              <pre data-yaml-target>{useCases[0].yaml}<span class="caret"></span></pre>
            </div>
          </div>
        </div>
        {useCases.map((c) => (
          <script type="application/json" data-yaml={c.id} set:html={JSON.stringify({ yaml: c.yaml, kicker: c.kicker, label: c.label, deploy: `$ molecule deploy ./${c.id}.yml` })} is:inline />
        ))}
      </section>

      {/* PLATFORM PILLARS */}
      <section class="v2-section">
        <div class="v2-container">
          <div class="v2-section-head" data-reveal>
            <div class="v2-kicker">Platform</div>
            <h2 class="v2-h2">Eight pillars we wrote into the PRD.</h2>
          </div>
          <div class="v2-grid-4 v2-grid-tight">
            {pillars.map((p, i) => (
              <div class="v2-card v2-card-warm" data-reveal data-delay={(i % 4) * 70}>
                <div class="v2-keynum v2-keynum-warm">{p.k}</div>
                <h3 class="v2-card-title v2-card-title-sm">{p.title}</h3>
                <p class="v2-card-body v2-card-body-sm">{p.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* MARKETPLACE PROMO */}
      <section id="marketplace" class="v2-section v2-section-ink v2-section-relative">
        <canvas data-particle data-density="0.00004" data-line="140" data-color="warm"></canvas>
        <div class="v2-container v2-section-relative">
          <div class="v2-section-head" data-reveal>
            <div>
              <div class="v2-kicker">Marketplace</div>
              <h2 class="v2-h2">
                Buy a tool. Hire an Agent. Or import an entire department.
              </h2>
            </div>
            <a class="v2-btn v2-btn-primary" href="https://marketplace.moleculesai.app"
              >Open the Marketplace →</a
            >
          </div>
          <div class="v2-grid-3">
            {tiers.map((tr, i) => (
              <a
                class="v2-tier-card"
                data-reveal
                data-delay={i * 120}
                href="https://marketplace.moleculesai.app"
              >
                <div class="v2-tier-head">
                  <div class="v2-tier-glyph" set:html={
                    tr.glyph === "plugin"
                      ? `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><rect x="2" y="2" width="4" height="4" fill="currentColor"/><rect x="8" y="2" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="2" y="8" width="4" height="4" fill="currentColor" opacity="0.45"/><rect x="8" y="8" width="4" height="4" fill="currentColor"/></svg>`
                      : tr.glyph === "agent"
                        ? `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4" fill="none"/><circle cx="7" cy="7" r="1.8" fill="currentColor"/></svg>`
                        : `<svg width="22" height="22" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.6" fill="currentColor"/><circle cx="3" cy="11" r="1.6" fill="currentColor"/><circle cx="11" cy="11" r="1.6" fill="currentColor"/><line x1="7" y1="4.6" x2="7" y2="7" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="3" y2="9.4" stroke="currentColor" stroke-width="1.2"/><line x1="7" y1="7" x2="11" y2="9.4" stroke="currentColor" stroke-width="1.2"/></svg>`
                  } />
                  <div>
                    <span class="v2-tier-tag">{tr.tag}</span>
                    <h3 class="v2-tier-title">{tr.title}</h3>
                  </div>
                </div>
                <p class="v2-card-body">{tr.desc}</p>
                <div class="v2-tier-foot">
                  <span>{tr.count}</span><span class="browse">Browse →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      {/* COMPARISON */}
      <section class="v2-section">
        <div class="v2-container v2-narrow">
          <div class="v2-section-head" data-reveal>
            <div class="v2-kicker">Where we sit</div>
            <h2 class="v2-h2">Not a framework. Not Ops. Not Zapier.</h2>
          </div>
          <div class="v2-compare" data-reveal>
            <div class="v2-compare-row v2-compare-head">
              <div>Capability</div>
              {compareCols.map((c, i) => (
                <div class={i === 0 ? "is-us" : ""}>{c}</div>
              ))}
            </div>
            {compareRows.map((row) => (
              <div class="v2-compare-row" data-compare-row>
                <div>{row[0]}</div>
                {row.slice(1).map((v) => (
                  <div class={`val ${v === "✓" ? "ok" : v === "—" ? "no" : "partial"}`}>{v}</div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* FAQ */}
      <section class="v2-section v2-section-ink">
        <div class="v2-container v2-narrowest">
          <div class="v2-section-head" data-reveal>
            <div class="v2-kicker">FAQ</div>
            <h2 class="v2-h2">Common questions.</h2>
          </div>
          <div class="v2-faq" data-faq>
            {faqs.map(([q, a], i) => (
              <details class="v2-faq-item" open={i === 0}>
                <summary>
                  <span>{q}</span>
                  <span class="plus">+</span>
                </summary>
                <div class="v2-faq-a">{a}</div>
              </details>
            ))}
          </div>
        </div>
      </section>

      {/* FINAL CTA */}
      <section class="v2-section v2-section-relative v2-final">
        <canvas data-particle data-density="0.00009" data-line="130"></canvas>
        <div class="v2-container v2-narrowest v2-section-relative" style="text-align:center">
          <h2 class="v2-final-h2" data-reveal>
            Stop wiring agents.<br />
            <span class="v2-h1-shimmer">Start running an organization.</span>
          </h2>
          <p class="v2-final-p" data-reveal data-delay="100">
            Free during public beta. SaaS or self-hosted. Bring your runtime,
            bring your team — we'll bring the org.
          </p>
          <div class="v2-cta-row v2-cta-center" data-reveal data-delay="180">
            <a class="v2-btn v2-btn-primary v2-btn-lg" href="https://marketplace.moleculesai.app"
              >Browse the Marketplace</a
            >
            <a class="v2-btn v2-btn-ghost v2-btn-lg" href="https://app.moleculesai.app">Open Canvas</a>
          </div>
        </div>
      </section>
    </main>

    {/* FOOTER */}
    <footer class="v2-footer">
      <div class="v2-container v2-footer-grid">
        <div>
          <div class="v2-footer-brand">
            <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
              <circle cx="14" cy="6" r="2.5" fill="currentColor" />
              <circle cx="6" cy="20" r="2.5" fill="currentColor" />
              <circle cx="22" cy="20" r="2.5" fill="currentColor" />
              <circle cx="14" cy="14" r="1.6" fill="none" stroke="currentColor" stroke-width="1.2" />
            </svg>
            <span>Molecule AI</span>
          </div>
          <p>The operating system for AI agent organizations. Build, deploy, govern — org-shaped from day one.</p>
        </div>
        {[
          ["Product", ["Canvas", "Platform API", "Control Plane", "Customer App"]],
          ["Marketplace", ["Plugins (L1)", "Agents (L2)", "Org Bundles (L3)", "Publish"]],
          ["Runtimes", ["LangGraph", "Claude Code", "CrewAI", "AutoGen", "+5 more"]],
          ["Trust", ["EU AI Act", "OWASP", "SOC 2 (in progress)", "Audit trails"]],
        ].map(([h, items]) => (
          <div>
            <div class="v2-footer-h">{h}</div>
            {(items as string[]).map((it) => (
              <a>{it}</a>
            ))}
          </div>
        ))}
      </div>
      <div class="v2-container v2-footer-bottom">
        <span>© 2026 Molecule AI · 多智能体组织治理平台</span>
        <span>moleculesai.app · v2026.4</span>
      </div>
    </footer>

    <style is:global>
      body[data-v2] {
        --bg: #fafaf7;
        --bgElev: #ffffff;
        --bgInk: #f3f1ec;
        --line: #e6e2d8;
        --lineSoft: #efece4;
        --ink: #15181c;
        --inkMid: #5a5e66;
        --inkSoft: #8b8e95;
        --accent: #3b5bdb;
        --accentInk: #1a2f99;
        --warm: #c0532b;
        --good: #2f7a4d;
      }
      body[data-v2] {
        margin: 0;
        font-family:
          "Geist",
          -apple-system,
          BlinkMacSystemFont,
          system-ui,
          sans-serif;
        background: var(--bg);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
      }
      body[data-v2] *,
      body[data-v2] *::before,
      body[data-v2] *::after {
        box-sizing: border-box;
      }
      body[data-v2] .dot {
