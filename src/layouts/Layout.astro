---
import "../styles/global.css";
import { content, localePaths, type Locale } from "../i18n";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  image?: string;
}

const { locale, title, description, image = "/og-image.jpg" } = Astro.props;
const c = content[locale];

const pageTitle = title ?? `${c.siteMeta.fullName} — ${c.siteMeta.tagline}`;
const pageDescription = description ?? c.siteMeta.metaDescription;

const site = Astro.site?.toString() ?? "https://www.moleculesai.app/";
const currentPath = localePaths[locale];
const canonical = new URL(currentPath, site).toString();
const imgUrl = new URL(image, site).toString();
const imgType = image.endsWith(".jpg") || image.endsWith(".jpeg") ? "image/jpeg" : "image/png";

const ogLocale = locale === "zh" ? "zh_CN" : "en_US";
const ogAlt = locale === "zh" ? "en_US" : "zh_CN";

const alternates = [
  { hreflang: "en", href: new URL(localePaths.en, site).toString() },
  { hreflang: "zh-CN", href: new URL(localePaths.zh, site).toString() },
  { hreflang: "x-default", href: new URL(localePaths.en, site).toString() },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site}#org`,
      name: "Molecule AI",
      alternateName: "Molecule-AI",
      url: site,
      logo: {
        "@type": "ImageObject",
        url: new URL("/logo.png", site).toString(),
        width: 256,
        height: 256,
      },
      sameAs: [
        c.siteMeta.github,
        c.siteMeta.monorepo,
        c.siteMeta.docs,
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${site}#site`,
      url: site,
      name: "Molecule AI",
      description: c.siteMeta.description,
      publisher: { "@id": `${site}#org` },
      inLanguage: locale === "zh" ? "zh-CN" : "en-US",
    },
    {
      "@type": "SoftwareApplication",
      name: "Molecule AI",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Linux, macOS, Windows, Docker",
      description: c.siteMeta.description,
      url: site,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      author: { "@id": `${site}#org` },
      license: "https://github.com/Molecule-AI/molecule-monorepo/blob/main/LICENSE",
      softwareVersion: "main",
      keywords:
        "AI agents, multi-agent systems, agent orchestration, LangGraph, CrewAI, AutoGen, Claude Code, DeepAgents, control plane, MCP",
    },
    {
      "@type": "WebPage",
      "@id": canonical,
      url: canonical,
      name: pageTitle,
      description: pageDescription,
      isPartOf: { "@id": `${site}#site` },
      inLanguage: c.htmlLang,
      primaryImageOfPage: imgUrl,
    },
  ],
};
---

<!doctype html>
<html lang={c.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#050912" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="keywords"
      content="AI agent control plane, multi-agent orchestration, AI agent team management, heterogeneous AI agents, LangGraph CrewAI AutoGen control plane, Claude Code multi-agent, hierarchical memory AI agents, AI agent governance, AI agent workspace"
    />
    <meta name="author" content="Molecule-AI" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Molecule AI" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imgUrl} />
    <meta property="og:image:type" content={imgType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Molecule AI — the org-native control plane for heterogeneous AI agent teams" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imgUrl} />
    <meta name="twitter:image:alt" content="Molecule AI — the org-native control plane for heterogeneous AI agent teams" />

    <!-- Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="preload" as="image" href="/logo.png" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <a href="#main" class="mol-skip-link">
      {locale === "zh" ? "跳转到主内容" : "Skip to main content"}
    </a>
    <slot />
    <script>
      import "../scripts/site";
    </script>
  </body>
</html>
