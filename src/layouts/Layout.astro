---
import "../styles/global.css";
import { content, localePaths, type Locale } from "../i18n";
import { themeBootScript } from "../scripts/theme";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  image?: string;
  /** SSR default — Astro builds static HTML and crawlers see this.
   * Real users get their cookie/system preference applied by the
   * inline boot script before first paint, so this value only
   * affects no-script and the very first paint frame. Default
   * "dark" preserves the brand identity for crawlers; landing
   * pages opt into "light" explicitly. */
  theme?: "light" | "dark";
}

const { locale, title, description, image = "/og-image.jpg", theme = "dark" } = Astro.props;
const c = content[locale];

const pageTitle = title ?? `${c.siteMeta.fullName} — ${c.siteMeta.tagline}`;
const pageDescription = description ?? c.siteMeta.metaDescription;

const site = Astro.site?.toString() ?? "https://www.moleculesai.app/";
const currentPath = localePaths[locale];
const canonical = new URL(currentPath, site).toString();
const imgUrl = new URL(image, site).toString();
const imgType = image.endsWith(".jpg") || image.endsWith(".jpeg") ? "image/jpeg" : "image/png";

// Map every locale to its OG facebook-style tag. Adding a locale here
// (and to localePaths) auto-extends og:locale + og:locale:alternate
// without another ternary.
const OG_LOCALES: Record<Locale, string> = {
  en: "en_US",
  zh: "zh_CN",
  fr: "fr_FR",
  ja: "ja_JP",
  es: "es_ES",
};
const ogLocale = OG_LOCALES[locale];
const ogAlt = (Object.entries(OG_LOCALES) as [Locale, string][])
  .filter(([code]) => code !== locale)
  .map(([, val]) => val);

// Logo is the LCP-critical hero element on the landing pages (/, /zh/, /fr/, /es/),
// where Landing.astro renders it at hero scale. On interior pages
// (/pricing, /legal/terms) it's a 28×28 navbar mark — preloading it
// there wastes a high-priority connection slot that should go to the
// Inter woff2 fonts gating the real LCP (the page heading). Scope the
// preload to homepages only, derived from localePaths so adding a locale
// auto-extends without a long pathname OR chain.
const pathname = Astro.url.pathname;
const homepagePaths = new Set(
  Object.values(localePaths).flatMap((p) => (p === "/" ? [p] : [p, p.replace(/\/$/, "")])),
);
const isHomepage = homepagePaths.has(pathname);

const alternates = [
  { hreflang: "en", href: new URL(localePaths.en, site).toString() },
  { hreflang: "zh-CN", href: new URL(localePaths.zh, site).toString() },
  { hreflang: "fr", href: new URL(localePaths.fr, site).toString() },
  { hreflang: "ja", href: new URL(localePaths.ja, site).toString() },
  { hreflang: "es", href: new URL(localePaths.es, site).toString() },
  { hreflang: "x-default", href: new URL(localePaths.en, site).toString() },
];

// FAQ rich-snippet schema is only meaningful on the homepage where the
// FAQ section actually renders (Landing.astro #faq). Emitting it on
// /pricing or /legal/* would advertise content that doesn't exist on
// those URLs and risks Search Console "Unmatched FAQ" warnings, so we
// gate by isHomepage. Locale-specific question text flows through c.faq
// so each /zh, /fr, /ja, /es homepage gets correctly-localized snippets.
const faqPageEntity = isHomepage
  ? {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      isPartOf: { "@id": canonical },
      mainEntity: c.faq.items.map(({ q, a }) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    }
  : null;

const webPageEntity: Record<string, unknown> = {
  "@type": "WebPage",
  "@id": canonical,
  url: canonical,
  name: pageTitle,
  description: pageDescription,
  isPartOf: { "@id": `${site}#site` },
  inLanguage: c.htmlLang,
  primaryImageOfPage: imgUrl,
};
if (faqPageEntity) {
  // Cross-link the WebPage to its FAQPage so Google can pair them up
  // when ranking the rich-snippet block, instead of treating FAQPage
  // as a free-floating entity in the graph.
  webPageEntity.mainEntity = { "@id": faqPageEntity["@id"] };
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site}#org`,
      name: "Molecule AI",
      alternateName: "Molecule-AI",
      url: site,
      logo: {
        "@type": "ImageObject",
        url: new URL("/logo.svg", site).toString(),
        width: 256,
        height: 256,
      },
      sameAs: [
        c.siteMeta.github,
        c.siteMeta.monorepo,
        c.siteMeta.docs,
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${site}#site`,
      url: site,
      name: "Molecule AI",
      description: c.siteMeta.description,
      publisher: { "@id": `${site}#org` },
      inLanguage: c.htmlLang,
    },
    {
      "@type": "SoftwareApplication",
      name: "Molecule AI",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Linux, macOS, Windows",
      description: c.siteMeta.description,
      url: site,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      author: { "@id": `${site}#org` },
      license: "https://github.com/Molecule-AI/molecule-monorepo/blob/main/LICENSE",
      softwareVersion: "Phase 34",
      keywords:
        "AI agents, multi-agent systems, agent orchestration, LangGraph, CrewAI, AutoGen, Claude Code, DeepAgents, Hermes, Gemini CLI, OpenClaw, control plane, MCP, A2A protocol",
    },
    webPageEntity,
    ...(faqPageEntity ? [faqPageEntity] : []),
  ],
};
---

<!doctype html>
<html lang={c.htmlLang} data-theme={theme}>
  <head>
    {/* Synchronous boot script — must run before any styles to prevent
        FOUC. Reads the molecule_theme cookie + system preference and
        stamps data-theme on <html> in <1ms. Only <html> is stamped:
        every theme-aware selector cascades from :root[data-theme], so
        body inherits without a JS body-update step that would race
        with DOMContentLoaded. is:inline keeps Astro from treating it
        as a module and deferring it. */}
    <script is:inline set:html={themeBootScript} />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {/* Both modes are supported — tells the browser to render form
        controls + scrollbars correctly in either. */}
    <meta name="color-scheme" content="light dark" />
    {/* Disable iOS Safari's auto-link of digit-shaped strings as
        phone/date/address. The page has many numbers (Phase 35,
        4500+ tests, 200+ endpoints) that iOS otherwise renders as
        tappable phone numbers, hurting both visual and tap-target UX. */}
    <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
    {/* Two theme-color values keyed by user pref so iOS/Android
        chrome adopt the right hue regardless of which theme the
        boot script resolves to. */}
    <meta name="theme-color" content="#fafaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#050912" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="keywords"
      content="AI agent control plane, multi-agent orchestration, AI agent team management, heterogeneous AI agents, LangGraph CrewAI AutoGen control plane, Claude Code multi-agent, hierarchical memory AI agents, AI agent governance, AI agent workspace"
    />
    <meta name="author" content="Molecule-AI" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Molecule AI" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imgUrl} />
    <meta property="og:image:type" content={imgType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${c.siteMeta.fullName} — ${c.siteMeta.tagline}`} />
    <meta property="og:locale" content={ogLocale} />
    {ogAlt.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imgUrl} />
    <meta name="twitter:image:alt" content={`${c.siteMeta.fullName} — ${c.siteMeta.tagline}`} />

    <!-- Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* dns-prefetch for the third-party domains every CTA on the page
        points at: app (sign-in / dashboard), doc (every adapter +
        trust + architecture link), market (pricing tier links),
        github (primary hero CTA + footer source links). Resolving
        DNS while the user is reading the hero saves ~50–200ms off
        the first click-through, with no resource cost — dns-prefetch
        is fire-and-forget and ignored by browsers that don't
        support it. Kept distinct from preconnect because we don't
        want to spend a TCP+TLS slot on click-targets that may
        never fire; preconnect stays reserved for fonts which
        block first paint. */}
    <link rel="dns-prefetch" href="https://app.moleculesai.app" />
    <link rel="dns-prefetch" href="https://doc.moleculesai.app" />
    <link rel="dns-prefetch" href="https://market.moleculesai.app" />
    <link rel="dns-prefetch" href="https://github.com" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {/* fetchpriority="high" reinforces the LCP signal on the homepage
        logo preload. Header.astro's <img> already carries it; pairing
        it on the preload <link> tells the browser to prioritise the
        bytes from the moment the head is parsed, before the <img>
        tag is reached. Chrome/Edge respect it, Firefox/Safari ignore
        it gracefully — additive, no regression risk. */}
    {isHomepage && <link rel="preload" as="image" href="/logo.svg" fetchpriority="high" />}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    {/* Progressive-enhancement fallback: [data-reveal] starts at opacity:0
        and only becomes visible when the IntersectionObserver in
        scripts/site.ts adds [data-visible]. With JS disabled (NoScript,
        paranoid configs, some non-JS crawlers) the data-visible attr
        never lands and the page renders blank. Force visible at all
        times when JS is off — the entrance animation is a polish layer,
        not a load-bearing one. Same fallback for .mol-entrance. */}
    <noscript>
      <style>{`
        [data-reveal] { opacity: 1 !important; transform: none !important; }
        [data-reveal="stagger"] > * { opacity: 1 !important; transform: none !important; }
        .mol-entrance { opacity: 1 !important; transform: none !important; animation: none !important; }
      `}</style>
    </noscript>
  </head>
  <body>
    {/* Scroll-driven progress bar at the very top of the viewport.
        Pure CSS via animation-timeline:scroll(root) — no JS, no rAF,
        no scroll listener. Browsers without scroll-driven-animations
        support (older Safari/Firefox) see scaleX(0), which renders
        as a 0-width invisible bar — graceful no-op fallback. Sits
        above the skip-link and the rest of the page chrome. */}
    <div class="mol-scroll-progress" aria-hidden="true"></div>
    <a href="#main" class="mol-skip-link">
      {locale === "zh"
        ? "跳转到主内容"
        : locale === "fr"
          ? "Aller au contenu principal"
          : locale === "ja"
            ? "メインコンテンツへスキップ"
            : locale === "es"
              ? "Saltar al contenido principal"
              : "Skip to main content"}
    </a>
    <slot />
    <script>
      import "../scripts/site";
    </script>
  </body>
</html>
